function normalizeStatus(v) {
    if (v === undefined || v === null) return "";
    return (v + "").trim();
}

function ensureDefaultStatusSelected() {
    var v = normalizeStatus($('#ddlStatus').val());
    // If nothing selected / placeholder selected, default to Pending (previous behavior)
    if (v === "" || v === "-1") {
        $('#ddlStatus').val('Pending');
    }
}

function buildScheduleStatusFilter() {
    ensureDefaultStatusSelected();
    var status = normalizeStatus($('#ddlStatus').val());
    if (status === "" || status === "-1") return "";
    return "TPTPL_Schedule_status eq '" + status.replace(/'/g, "''") + "'";
}

