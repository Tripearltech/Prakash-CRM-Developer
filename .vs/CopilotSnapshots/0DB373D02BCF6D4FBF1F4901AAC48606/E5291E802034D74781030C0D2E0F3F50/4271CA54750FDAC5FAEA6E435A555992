        public async Task<JsonResult> GetWarehouseTaskAll(int orderBy, string orderDir, string filter, string documenttype = "")
        {
            string apiUrl = ConfigurationManager.AppSettings["ServiceApiUrl"].ToString() + "SPWarehouse/";

            // UI-only filter support (fields not available in the service API filter layer)
            Func<SPWarehouseList, bool> uiPredicate = null;
            string serviceFilter = filter;
            if (TryBuildWarehouseUiPredicate(filter, out uiPredicate, out serviceFilter))
            {
                filter = serviceFilter;
            }

            string orderByField = "";

            switch (orderBy)
            {
                case 1:
                    orderByField = "Document_No " + orderDir;
                    break;
                case 2:
                    orderByField = "Sell_to_Customer_No " + orderDir;
                    break;
                case 3:
                    orderByField = "PCPL_Sell_to_Customer_Name " + orderDir;
                    break;
                case 4:
                    orderByField = "Location_Code " + orderDir;
                    break;
                case 5:
                    orderByField = "Shipment_Date " + orderDir;
                    break;
                default:
                    orderByField = "Shipment_Date asc";
                    break;
            }

            orderByField = orderByField + ",Document_No asc";
            apiUrl = apiUrl + "GetWarehouseTaskAll?orderby=" + HttpUtility.UrlEncode(orderByField) + "&filter=" + HttpUtility.UrlEncode(filter ?? "");

            HttpClient client = new HttpClient();
            List<SPWarehouseList> warehouseAll = new List<SPWarehouseList>();

            client.BaseAddress = new Uri(apiUrl);
            client.DefaultRequestHeaders.Accept.Clear();
            client.DefaultRequestHeaders.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("application/json"));

            HttpResponseMessage response = await client.GetAsync(apiUrl);
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadAsStringAsync();
                warehouseAll = Newtonsoft.Json.JsonConvert.DeserializeObject<List<SPWarehouseList>>(data);
            }

            if (uiPredicate != null)
                warehouseAll = warehouseAll.Where(uiPredicate).ToList();

            // Apply in-memory sorting for UI columns (WarehouseList page).
            // This is more reliable than relying on backend orderby fields because this endpoint merges multiple document types.
            Func<SPWarehouseList, object> keySelector = x => x?.DocumentNo;
            switch (orderBy)
            {
                case 1: // Order No
                    keySelector = x => (x?.DocumentNo ?? "");
                    break;
                case 2: // Shipment Date
                    keySelector = x => ParseWarehouseDate(x?.ShipmentDate);
                    break;
                case 3: // Customer/Vendor Name
                    keySelector = x => (x?.CustomerVendorName ?? "");
                    break;
                case 4: // From Location
                    keySelector = x => (x?.FromLocation ?? "");
                    break;
                case 5: // To Location
                    keySelector = x => (x?.ToLocation ?? "");
                    break;
                case 6: // Document Type
                    keySelector = x => (x?.DocumentType ?? "");
                    break;
                case 7: // Accepted By
                    keySelector = x => (x?.AcceptedBy ?? "");
                    break;
                case 8: // Inco Term
                    keySelector = x => (x?.IncoTerm ?? "");
                    break;
                case 9: // From Address
                    keySelector = x => (x?.FromAddress ?? "");
                    break;
                case 10: // To Address
                    keySelector = x => (x?.ToAddress ?? "");
                    break;
            }

            bool isDesc = string.Equals(orderDir, "desc", StringComparison.OrdinalIgnoreCase);
            var sorted = isDesc
                ? warehouseAll.OrderByDescending(keySelector).ThenBy(x => x.DocumentNo)
                : warehouseAll.OrderBy(keySelector).ThenBy(x => x.DocumentNo);

            return Json(sorted.ToList(), JsonRequestBehavior.AllowGet);
        }

        private static DateTime ParseWarehouseDate(string input)
        {
            if (string.IsNullOrWhiteSpace(input)) return DateTime.MinValue;
            var s = input.Trim();

            // Try common formats first, then fall back to DateTime.TryParse.
            var formats = new[] { "yyyy-MM-dd", "dd-MM-yyyy", "MM-dd-yyyy", "dd/MM/yyyy", "MM/dd/yyyy", "yyyy/MM/dd" };
            if (DateTime.TryParseExact(s, formats, CultureInfo.InvariantCulture, DateTimeStyles.AllowWhiteSpaces, out var dtExact))
                return dtExact;

            if (DateTime.TryParse(s, CultureInfo.InvariantCulture, DateTimeStyles.AllowWhiteSpaces, out var dt))
                return dt;

            return DateTime.MinValue;
        }

        private static bool TryBuildWarehouseUiPredicate(string filter, out Func<SPWarehouseList, bool> predicate, out string remainingFilter)
        {
            predicate = null;
            remainingFilter = filter;
            if (string.IsNullOrWhiteSpace(filter)) return false;

            // Support: DocumentType_UI ... (UI-only; service API endpoints don't have this field)
            var parts = filter.Split(new[] { " and " }, StringSplitOptions.None)
                .Select(p => (p ?? string.Empty).Trim())
                .Where(p => p.Length > 0)
                .ToList();

            var docPart = parts.FirstOrDefault(p => p.IndexOf("DocumentType_UI", StringComparison.OrdinalIgnoreCase) >= 0);
            if (string.IsNullOrWhiteSpace(docPart)) return false;

            remainingFilter = string.Join(" and ", parts.Where(p => !ReferenceEquals(p, docPart) && p.IndexOf("DocumentType_UI", StringComparison.OrdinalIgnoreCase) < 0));

            string ExtractBetween(string src, string start, string end)
            {
                var sIdx = src.IndexOf(start, StringComparison.OrdinalIgnoreCase);
                if (sIdx < 0) return string.Empty;
                sIdx += start.Length;
                var eIdx = src.IndexOf(end, sIdx, StringComparison.OrdinalIgnoreCase);
                if (eIdx < 0) return string.Empty;
                return src.Substring(sIdx, eIdx - sIdx);
            }

            string ExtractQuotedValue(string src)
            {
                var first = src.IndexOf("'", StringComparison.OrdinalIgnoreCase);
                if (first < 0) return string.Empty;
                var second = src.IndexOf("'", first + 1, StringComparison.OrdinalIgnoreCase);
                if (second < 0) return string.Empty;
                return src.Substring(first + 1, second - first - 1);
            }

            Func<string, string> norm = s => (s ?? string.Empty).Trim();
            Func<SPWarehouseList, string> docVal = x => (x?.DocumentType ?? string.Empty).Trim();

            if (docPart.StartsWith("DocumentType_UI eq", StringComparison.OrdinalIgnoreCase))
            {
                var val = norm(ExtractQuotedValue(docPart));
                if (val.StartsWith("@*", StringComparison.Ordinal) && val.EndsWith("*", StringComparison.Ordinal) && val.Length >= 3)
                {
                    var needle = val.Substring(2, val.Length - 3);
                    predicate = x => docVal(x).IndexOf(needle, StringComparison.OrdinalIgnoreCase) >= 0;
                }
                else
                {
                    predicate = x => string.Equals(docVal(x), val, StringComparison.OrdinalIgnoreCase);
                }
                return true;
            }

            if (docPart.StartsWith("DocumentType_UI ne", StringComparison.OrdinalIgnoreCase))
            {
                var val = norm(ExtractQuotedValue(docPart));
                predicate = x => !string.Equals(docVal(x), val, StringComparison.OrdinalIgnoreCase);
                return true;
            }

            if (docPart.StartsWith("startswith(DocumentType_UI", StringComparison.OrdinalIgnoreCase))
            {
                var val = norm(ExtractBetween(docPart, "startswith(DocumentType_UI,'", "')"));
                predicate = x => docVal(x).StartsWith(val, StringComparison.OrdinalIgnoreCase);
                return true;
            }

            if (docPart.StartsWith("endswith(DocumentType_UI", StringComparison.OrdinalIgnoreCase))
            {
                var val = norm(ExtractBetween(docPart, "endswith(DocumentType_UI,'", "')"));
                predicate = x => docVal(x).EndsWith(val, StringComparison.OrdinalIgnoreCase);
                return true;
            }

            // If unknown format, ignore safely.
            return true;
        }

