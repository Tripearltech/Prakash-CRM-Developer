                case 1:
                    orderByField = "Document_No " + orderDir;
                    break;
                case 2:
                    orderByField = "Sell_to_Customer_No " + orderDir;
                    break;
                case 3:
                    orderByField = "PCPL_Sell_to_Customer_Name " + orderDir;
                    break;
                case 4:
                    orderByField = "Location_Code " + orderDir;
                    break;
                case 5:
                    orderByField = "Shipment_Date " + orderDir;
                    break;
                default:
                    orderByField = "Shipment_Date asc";
                    break;
            }

            orderByField = orderByField + ",Document_No asc";
            apiUrl = apiUrl + "GetWarehouseClosedTaskAll?orderby=" + HttpUtility.UrlEncode(orderByField) + "&filter=" + HttpUtility.UrlEncode(filter ?? "");

            HttpClient client = new HttpClient();
            List<SPWarehouseList> warehouseAll = new List<SPWarehouseList>();

            client.BaseAddress = new Uri(apiUrl);
            client.DefaultRequestHeaders.Accept.Clear();
            client.DefaultRequestHeaders.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("application/json"));

            HttpResponseMessage response = await client.GetAsync(apiUrl);
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadAsStringAsync();
                warehouseAll = Newtonsoft.Json.JsonConvert.DeserializeObject<List<SPWarehouseList>>(data);
            }

            if (uiPredicate != null)
                warehouseAll = warehouseAll.Where(uiPredicate).ToList();

            // Apply in-memory sorting for UI columns (WarehouseClosedList page).
            Func<SPWarehouseList, object> keySelector = x => x?.DocumentNo;
            switch (orderBy)
            {
                case 1: // Order No
                    keySelector = x => (x?.DocumentNo ?? "");
                    break;
                case 2: // Shipment Date
                    keySelector = x => ParseWarehouseDate(x?.ShipmentDate);
                    break;
                case 3: // Customer/Vendor Name
                    keySelector = x => (x?.CustomerVendorName ?? "");
                    break;
                case 4: // Document Type
                    keySelector = x => (x?.DocumentType ?? "");
                    break;
                case 5: // Accepted By
                    keySelector = x => (x?.AcceptedBy ?? "");
                    break;
                case 6: // Inco Term
                    keySelector = x => (x?.IncoTerm ?? "");
                    break;
                case 7: // From Address
                    keySelector = x => (x?.FromAddress ?? "");
                    break;
                case 8: // To Address
                    keySelector = x => (x?.ToAddress ?? "");
                    break;
            }

            bool isDesc = string.Equals(orderDir, "desc", StringComparison.OrdinalIgnoreCase);
            var sorted = isDesc
                ? warehouseAll.OrderByDescending(keySelector).ThenBy(x => x.DocumentNo)
                : warehouseAll.OrderBy(keySelector).ThenBy(x => x.DocumentNo);

            return Json(sorted.ToList(), JsonRequestBehavior.AllowGet);
        }

