function SaveWarehouseItemTracking() {
    $('#lblItemTrackMsg').html('');

    var originalBalance = parseFloat($('#txtbalanceQty').data('original')) || 0;
    var total = getTotalQuantityToHandle();
    var balance = originalBalance - total;

    if (Math.abs(balance) > 0.0001) {
        $('#lblItemTrackMsg').html('<span style="color: red;">Lot is not yet defined for "' + balance.toFixed(2) + '" Qty.</span>');
        return false;
    }

    if (total > originalBalance) {
        $('#lblItemTrackMsg').html('<span style="color: red;">Total quantity cannot exceed Transport quantity.</span>');
        return false;
    }

    var documentType = $('#lblDocumentType').text().trim();
    var orderNo = $('#lnlDocumentNo').text().trim();
    var locationCode = $('#hfFromLocationCode').val() || $('#hfToLocationCode').val() || "";
    var reservationEntryforGRN = [];

    $('#tbItemTrackingLines .itemtrackingtr').each(function () {
        var $tds = $(this).find('td');
        var entryNo = $tds.eq(0).text().trim() || "0";
        var lineNo = $tds.eq(1).text().trim();
        var itemNo = $tds.eq(2).text().trim();
        var lotNo = $tds.eq(3).find('input').val() || "";
        var qtyToHandleDisplay = toPositiveNumber($tds.eq(4).find('input').val());
        var qtyToHandle = toNegativeNumber(qtyToHandleDisplay);

        if (!lineNo || qtyToHandleDisplay === 0) {
            return;
        }

        reservationEntryforGRN.push({
            EntryNo: entryNo,
            DocumentType: documentType,
            OrderNo: orderNo,
            LocationCode: locationCode,
            LineNo: lineNo,
            ItemNo: itemNo,
            LotNo: lotNo,
            Qty: qtyToHandle
        });
    });

    if (reservationEntryforGRN.length === 0) {
        $('#lblItemTrackMsg').html('<span style="color: red;">No valid item tracking lines to save.</span>');
        return false;
    }

    var $warehouseSaveBtn = $('#btnSaveItemTrackingWarehouse');
    var warehouseSaveBtnHtml = $warehouseSaveBtn.html();
    $warehouseSaveBtn.prop('disabled', true);
    $warehouseSaveBtn.html('<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Save');

    $.ajax({
        type: "POST",
        url: '/SPGRN/SaveGRNLineItemTracking',
        data: JSON.stringify(reservationEntryforGRN),
        contentType: "application/json; charset=utf-8",
        success: function (data) {
            if (data) {
                var trackedLineNo = reservationEntryforGRN.length > 0 ? reservationEntryforGRN[0].LineNo : '';
                if (trackedLineNo) {
                    itemTrackingTransportQtyByLine[trackedLineNo] = total;
                }
                $('#modalItemTracking').hide();
                ShowActionMsg("Item Tracking lines saved successfully.");
                $('#txtbalanceQty').val($('#txtbalanceQty').data('original').toFixed(2));
            } else {
                $('#lblItemTrackMsg').html('<span style="color: red;">Error saving Item Tracking data.</span>');
            }
        },
        error: function (xhr) {
            ShowErrMsg("Error in SaveGRNLineItemTracking API. " + xhr.responseText);
        },
        complete: function () {
            $warehouseSaveBtn.prop('disabled', false);
            $warehouseSaveBtn.html(warehouseSaveBtnHtml);
        }
    });
}

