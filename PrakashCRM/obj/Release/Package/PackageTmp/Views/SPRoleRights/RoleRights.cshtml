@model IEnumerable<PrakashCRM.Data.Models.SPMenuList>
@{
    ViewBag.Title = "RoleRights";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<style>
    .plus, .minus {
        display: inline-block;
        background-repeat: no-repeat;
        background-size: 16px 16px !important;
        width: 16px;
        height: 16px;
    }

    .plus {
        background-image: url("https://cdn.jsdelivr.net/gh/icons8/flat-color-icons/svg/plus.svg");
    }

    .minus {
        background-image: url("https://cdn.jsdelivr.net/gh/icons8/flat-color-icons/svg/minus.svg");
    }

    ul {
        list-style: none;
        padding-left: 20px;
    }

        ul.inner_ul li:before {
            content: "├";
            font-size: 18px;
            margin-left: -11px;
            margin-top: -5px;
            vertical-align: middle;
            float: left;
            width: 8px;
            color: #41424e;
        }

        ul.inner_ul li:last-child:before {
            content: "└";
        }

    .inner_ul {
        padding-left: 35px;
    }

    .menu-row {
        display: flex;
        align-items: center;
        gap: 30px;
        padding: 4px 0;
    }

    .menu-title {
        width: 350px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .rights-group {
        display: flex;
        gap: 90px;
        min-width: 350px;
    }

        .rights-group label {
            display: flex;
            align-items: center;
            gap: 6px;
        }

    /* header row styles */
    .tree-header {
        display: flex;
        align-items: center;
        gap: 30px;
        padding: 6px 0;
        font-weight: 600;
        border-bottom: 1px solid #e6e6e6;
        margin-bottom: 6px;
    }

        .tree-header .menu-title {
            width: 350px;
        }

        .tree-header .rights-group {
            min-width: 350px;
            gap: 28px;
        }
</style>

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Role Rights
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="row mb-3">
                                <label class="col-sm-3 col-form-label">Role</label>
                                <div class="col-sm-9">
                                    <input id="hdnSavedMenuRightsValues" style="display:none" />
                                    <input id="hdnRolewiseMenuRightsJson" style="display:none" />
                                    <select id="ddlRoles" class="form-select">
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-2">
                            <input id="_chk_Full_Rights" type="checkbox" /> Full Rights
                        </div>
                        <div class="col-md-2" hidden>
                            <input id="_chk_Add_Rights" type="checkbox" /> Add Rights
                        </div>
                        <div class="col-md-2" hidden>
                            <input id="_chk_Edit_Rights" type="checkbox" /> Edit Rights
                        </div>
                        <div class="col-md-2" hidden>
                            <input id="_chk_View_Rights" type="checkbox" /> View Rights
                        </div>
                        <div class="col-md-2" hidden>
                            <input id="_chk_Delete_Rights" type="checkbox" /> Delete Rights
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <div class="row mb-3">
                                <div class="col-sm-12">

                                    <div class="verticalScroll">
                                        <div class="tree_main">

                                            <!-- HEADER ROW (Version A) -->
                                            <div class="tree-header">
                                                <div class="menu-title">
                                                    <span style="width:16px;display:inline-block"></span>
                                                    <span style="margin-left:6px" hidden>Menu Name</span>
                                                </div>
                                                <div class="rights-group">
                                                    <span hidden>Add Rights</span>
                                                    <span hidden>Edit Rights</span>
                                                    <span hidden>View Rights</span>
                                                    <span hidden>Delete Rights</span>
                                                </div>
                                            </div>

                                            <ul id="bs_main" class="main_ul">

                                                @foreach (var item in Model)
                                                {
                                                    <li id="bs_@item.No">

                                                        <div class="menu-row">
                                                            <div class="menu-title">
                                                                @if (item.subMenuList.Count > 0)
                                                                {
                                                                    <span class="plus">&nbsp;</span>
                                                                    <span style="width:16px;display:inline-block"></span>
                                                                    <input type="checkbox" id="c_bs_@item.No-@item.No" />
                                                                }
                                                                else
                                                                {
                                                                    <span style="width:16px;display:inline-block"></span>
                                                                    <input type="checkbox" id="c_bs_@item.No-@item.No" />
                                                                }
                                                                <span>@item.Menu_Name</span>
                                                            </div>

                                                            @* Show rights only for leaf menus (menus that have a checkbox) *@
                                                            @if (item.subMenuList.Count == 0)
                                                            {
                                                                <div class="rights-group">
                                                                    <label><input type="checkbox" id="add_@item.No" /> Add Right</label>
                                                                    <label><input type="checkbox" id="edit_@item.No" /> Edit Right</label>
                                                                    <label><input type="checkbox" id="view_@item.No" /> View Right</label>
                                                                    <label><input type="checkbox" id="delete_@item.No" /> Delete Right</label>
                                                                </div>
                                                            }
                                                        </div>

                                                        @if (item.subSubListCnt > 0)
                                                        {
                                                            <ul id="bs_sub_sub_@item.No" style="display:none" class="sub_ul">
                                                                @foreach (var item1 in item.subMenuList)
                                                                {
                                                                    <li id="bf_@item1.No">

                                                                        <div class="menu-row">
                                                                            <div class="menu-title">
                                                                                <span class="plus">&nbsp;</span>
                                                                                <span style="width:16px;display:inline-block"></span>
                                                                                <input type="checkbox" id="c_bf_@item.No-@item1.No" />
                                                                                <span>@item1.Menu_Name</span>
                                                                            </div>

                                                                            @* This is a parent node (has sub-sub menus) → hide rights on parent row *@
                                                                        </div>

                                                                        <ul id="bf_sub_sub_@item1.No" style="display:none" class="inner_ul">
                                                                            @foreach (var item2 in item1.subSubMenuList)
                                                                            {
                                                                                <li id="io_@item1.No-@item2.No">

                                                                                    <div class="menu-row">
                                                                                        <div class="menu-title">
                                                                                            <span style="width:16px;display:inline-block"></span>
                                                                                            <input type="checkbox" id="c_io_@item1.No-@item2.No" />
                                                                                            <span>@item2.Menu_Name</span>
                                                                                        </div>

                                                                                        <div class="rights-group">
                                                                                            <label><input type="checkbox" id="add_@item2.No" /> Add Right</label>
                                                                                            <label><input type="checkbox" id="edit_@item2.No" /> Edit Right</label>
                                                                                            <label><input type="checkbox" id="view_@item2.No" /> View Right</label>
                                                                                            <label><input type="checkbox" id="delete_@item2.No" /> Delete Right</label>
                                                                                        </div>
                                                                                    </div>

                                                                                </li>
                                                                            }
                                                                        </ul>

                                                                    </li>
                                                                }
                                                            </ul>
                                                        }
                                                        else
                                                        {
                                                            <ul id="bs_sub_@item.No" style="display:none" class="inner_ul">
                                                                @foreach (var item1 in item.subMenuList)
                                                                {
                                                                    <li id="bf_@item1.No">

                                                                        <div class="menu-row">
                                                                            <div class="menu-title">
                                                                                <span style="width:16px;display:inline-block"></span>
                                                                                <input type="checkbox" id="c_bf_@item.No-@item1.No" />
                                                                                <span>@item1.Menu_Name</span>
                                                                            </div>

                                                                            <div class="rights-group">
                                                                                <label><input type="checkbox" id="add_@item1.No" /> Add Right</label>
                                                                                <label><input type="checkbox" id="edit_@item1.No" /> Edit Right</label>
                                                                                <label><input type="checkbox" id="view_@item1.No" /> View Right</label>
                                                                                <label><input type="checkbox" id="delete_@item1.No" /> Delete Right</label>
                                                                            </div>
                                                                        </div>

                                                                    </li>
                                                                }
                                                            </ul>
                                                        }

                                                    </li>
                                                }

                                            </ul>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="toolbar">
                <div class=" text-end g-3">

                    <input type="hidden" id="hdnRoleRightsAction" value="@Session["RoleRightsAction"]" />
                    <input id="hdnLoggedInUserNo" value="@Session["loggedInUserNo"]" style="display:none" />
                    <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                    <input id="getAppBaseUrl" value="@Url.Content("~/")" style="display:none" />
                    <span id="btnSaveLoader" class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true" style="display:none;"></span>
                    <button id="btnSave" class="btn btn-success" type="button"><i class="bx bxs-save"></i> Save</button>
                    &nbsp;
                    <a href="/SPDashboard/Index" class="btn btn-danger"><i class="lni lni-close"></i> Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

@Scripts.Render("~/bundles/jquery")

<script src="~/Scripts/appjs/RoleRights.js"></script>
@*<script>
        var apiUrl = $('#getServiceApiUrl').val() + 'SPRoleRights/';

        $(document).ready(function () {

            BindRoles();
            $(document).on('click', 'input[type=checkbox]', function () {
