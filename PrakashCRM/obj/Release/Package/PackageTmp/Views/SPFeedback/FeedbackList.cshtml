@model PrakashCRM.Data.Models.CustomerDropdown
@{
    ViewBag.Title = "FeedbackList";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Feedback List</li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row align-items-end g-3 mb-3 filter-bar">
                <div class="col-md-2">
                    <div class="" id="spinnerId" style="width: 200px;">
                        <span class="input-group-text" id="loader" style="display: none;">
                            <span class="spinner-border spinner-border-sm text-primary"></span>
                        </span>
                        <input type="text" id="txtCustomer_Name" class="form-control" placeholder="Contact Company Name" value="@Model.Company_Name" />
                    </div>
                    <input type="hidden" id="hfCustomerNo" name="" value="@Model.Company_No" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">From Date</label>
                    <input type="date" id="txtFromDate" class="form-control" value="" />
                    <span class="text-danger" id="Fdatevalidate"></span>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">To Date</label>
                    <input type="date" id="txtToDate" class="form-control" value="" />
                    <span class="text-danger" id="Tdatevalidate"></span>
                </div>

                <div class="col-md-4 d-flex justify-content-end gap-2">
                    <button id="SearchBtn" class="btn btn-primary px-4">Search</button>
                    <button id="btnClearFilter" class="btn btn-primary">
                        <i class="bx bx-rotate-right"></i> Refresh
                    </button>
                    <button id="btnExport" class="btn btn-warning text-white px-4">Export</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>No</th>
                            <th>Date</th>
                            <th>Contact No.</th>
                            <th>Contact Person</th>
                            <th>Contact Company</th>
                            <th>Products</th>
                            <th>Overall Rating</th>
                            <th>Comments</th>
                            <th>Suggestion</th>
                            <th>Sales Person</th>
                        </tr>
                    </thead>
                    <tbody id="tblFeedBacklist">
                        <!-- Dynamic rows -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<div class="modal fade" id="FeedbackLinesModal" tabindex="-1" aria-labelledby="FeedbackLinesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Feedback Question</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height: 450px; overflow-y: auto;">
                <table class="table mb-0 table-striped">
                    <thead class="sticky-top bg-white" style="top: -20px;">
                        <tr>
                            <th scope="col">Feedback Question No.</th>
                            <th scope="col">Feedback Question</th>
                            <th scope="col">Rating</th>
                            <th scope="col">Comments</th>
                        </tr>
                    </thead>
                    <tbody id="tblFeedbackLine"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/appjs/SPFeedbackList.js"></script>
