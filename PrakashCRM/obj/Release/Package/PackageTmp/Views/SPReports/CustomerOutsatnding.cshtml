
@{
    ViewBag.Title = "CustomerOutsatnding";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<link href="~/Content/appcss/paginationFilterCss.css" rel="stylesheet" />

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="#"> Reports </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Collection Report Summary
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div id="customerOutstandingPageSection" class="position-relative">
        <div id="customerOutstandingLoader" class="customer-outstanding-loader d-none">
            <div class="customer-outstanding-loader-content app-loader-card">
                <span class="app-loader-spinner customer-outstanding-loader-spinner" role="status" aria-label="Loading"></span>
                <div class="app-loader-text">Loading data...</div>
            </div>
        </div>
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <div class="row">
                    <div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                                <table id="dataList" class="table mb-0 table-striped">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th scope="col">SP Branch</th>
                                            <th scope="col">Col. Upto MTD-1 Date</th>
                                            <th scope="col">Date on Title - TD</th>
                                            <th scope="col">Total Collection</th>
                                            <th scope="col">Overdue CM-1</th>
                                            <th scope="col">1st-10th Due Cur. Month</th>
                                            <th scope="col">11th-20th Due Cur. Month</th>
                                            <th scope="col">21st-30th Due Cur. Month</th>
                                            <th scope="col">Total Due Cur. Month</th>
                                            <th scope="col">Achievement in %</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblOutstanding">
                                        <tr>
                                            <td></td>
                                            <td><a id="tblInvBranch1Rec" class="clsPointer"></a></td>
                                        </tr>
                                    </tbody>
                                    <tfoot></tfoot>
                                    @*<thead>
                                            <tr>
                                                <th ></th>
                                                <th scope="col">Customer Name</th>
                                                <th scope="col">Class</th>
                                                <th scope="col">Amount (Rs)</th>
                                                <th scope="col">ACD</th>
                                                <th scope="col">ADD</th>
                                                <th scope="col">To do list with remark</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblCustomerData">
                                        </tbody>*@
                                </table>
                                <input id="hdnCustomerOutstandingCount" style="display:none" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div>
                <div class="row">
                    <div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <span class="small fw-semibold text-muted">All Records</span>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>
<div class="modal fade" id="itemDetailsModal" tabindex="-1" aria-labelledby="itemDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="itemDetailsModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" style="max-height: 450px; overflow-y: auto;">
                <table class="table mb-0 table-striped">
                    <thead class="sticky-top bg-white" style="top: -20px;"></thead>
                    <tbody id="tblCustomerData"></tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="customerDetailModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="customerDetailModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" style="max-height:450px; overflow-y:auto;">
                <table class="table mb-0 table-striped">
                    <thead id="customerDetailThead" class="sticky-top bg-white"></thead>
                    <tbody id="customerDetailBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>



@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/reportjs/CustomerOutsatnding.js"></script>
