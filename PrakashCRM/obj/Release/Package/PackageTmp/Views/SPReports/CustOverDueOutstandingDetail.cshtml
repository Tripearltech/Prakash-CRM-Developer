@{
    ViewBag.Title = "CustOverDueOutstandingDetail";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<link href="~/Content/appcss/paginationFilterCss.css" rel="stylesheet" />

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="#"> Reports </a>
                    </li>
                    <li class="breadcrumb-item">
                        <a id="custOverdueListLink" href="/SPReports/CustOverDueOutstandinglist">Customer List</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Customer Detail
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />

    <div class="card">
        <div class="card-body position-relative">
            <div id="custOverdueDetailLoader" class="customer-outstanding-loader d-none" aria-hidden="true">
                <div class="customer-outstanding-loader-content app-loader-card text-center">
                    <span class="app-loader-spinner customer-outstanding-loader-spinner" role="status" aria-label="Loading"></span>
                    <div class="app-loader-text">Loading report data...</div>
                </div>
            </div>

            <input id="hdnLoggedInSPCode" type="hidden" value="@Convert.ToString(Session["loggedInUserSPCode"])" />
            <input type="hidden" id="hdnCustomerName" value="@Convert.ToString(ViewBag.CustomerName)" />
            <input type="hidden" id="hdnAsOnDate" value="@Convert.ToString(ViewBag.AsOnDate)" />

            <div class="row align-items-center mb-3">
                <div class="col">
                    <h5 class="mb-0" id="customerDetailTitle"></h5>
                </div>
                <div class="col-auto">
                    <a id="custOverdueBackLink" href="/SPReports/CustOverDueOutstandinglist" class="btn btn-danger"> Back</a>
                </div>
            </div>

            <div class="row g-2 align-items-center mb-3 flex-nowrap">

                <!-- Product Name -->
                <div class="col-auto d-flex align-items-center">
                    <label class="fw-semibold me-2 mb-0 form-inline-label">Product Name</label>
                    <input type="text" id="txtDetailProduct" class="form-control" style="width:220px;">
                </div>

                <!-- Bill No -->
                <div class="col-auto d-flex align-items-center">
                    <label class="fw-semibold me-2 mb-0 form-inline-label">Bill No</label>
                    <input type="text" id="txtDetailBillNo" class="form-control" style="width:180px;">
                </div>

                <!-- Document Type -->
                <div class="col-auto d-flex align-items-center">
                    <label class="fw-semibold me-2 mb-0 form-inline-label">Document Type</label>
                    <input type="text" id="txtDetailDocumentType" class="form-control"style="width:220px;">
                </div>

                <!-- Search -->
                <div class="col-auto">
                    <button id="btnDetailSearch" class="btn btn-primary">Search</button>
                </div>

                <!-- Refresh -->
                <div class="col-auto">
                    <button id="btnDetailRefresh" class="btn btn-success">Refresh</button>
                </div>

                <!-- Export -->
                <div class="col-auto d-flex align-items-center">
                    <label class="fw-semibold me-2 mb-0">Export</label>
                    <select id="ddlDetailExportType" class="form-select" style="width:120px;">
                        <option value="">--Select--</option>
                        <option value="Excel">Excel</option>
                        <option value="PDF">PDF</option>
                    </select>
                </div>

                <!-- Export Button -->
                <div class="col-auto">
                    <button id="btnDetailExport" class="btn btn-primary">Export</button>
                </div>

            </div>

            <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
                <table class="table table-striped table-hover table-bordered mb-0 align-middle" style="min-width:900px;">
                    <thead id="customerDetailThead" class="table-light">
                        <tr>
                            <th class="sticky-top bg-light">Document Type</th>
                            <th class="sticky-top bg-light">PO No</th>
                            <th class="sticky-top bg-light">Bill No</th>
                            <th class="sticky-top bg-light">Bill Date</th>
                            <th class="sticky-top bg-light">Product Name</th>
                            <th class="sticky-top bg-light">TERMS</th>
                            <th class="sticky-top bg-light">Due Date</th>
                            <th class="sticky-top bg-light">Invoice Amount (Rs)</th>
                            <th class="sticky-top bg-light">Remain Amount (Rs)</th>
                            <th class="sticky-top bg-light">Total days</th>
                            <th class="sticky-top bg-light">Overdue days</th>
                        </tr>
                    </thead>
                    <tbody id="customerDetailBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/reportjs/CustOverDueOutstandingDetail.js"></script>
