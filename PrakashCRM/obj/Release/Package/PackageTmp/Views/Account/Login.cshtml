@{
    Layout = null;
}

<!doctype html>
<html>
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!--favicon-->

    <title>Prakash - Login</title>
    <link rel="icon" type="image/x-icon" href="~/Layout/assets/images/login-images/favicon-1.ico">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap">
    <link href="~/Content/appcss/LoginOTPCss.css" rel="stylesheet" />
    @Styles.Render("~/bundles/commoncss")
    <style>
        .login-page-data-loader {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: blur(2px);
            z-index: 2000;
        }

        .login-page-data-loader__content {
            min-width: 140px;
        }

        .login-page-data-loader__spinner {
            width: 3.5rem;
            height: 3.5rem;
            border-width: 0.4rem;
        }
    </style>
</head>

<body>
    <!--wrapper-->
    <div class="wrapper">
        <div class="authentication-header"></div>
        <div class="section-authentication-signin d-flex align-items-center justify-content-center my-5 my-lg-0">
            <div class="container">
                <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3">
                    <div class="col mx-auto">
                        <div class="mb-4 text-center">
                            <img src="~/Layout/assets/images/logo-img.png" width="180" alt="" />
                        </div>
                        <div class="card rounded-4">
                            <div class="card-body">
                                <div class="p-4 rounded">
                                    <div class="text-center">
                                        <img src="~/Layout/assets/images/login-images/logo-2.jfif" width="250px" height="150px" />
                                    </div>
                                    <div class="form-body">
                                        <form class="row g-3">
                                            <div class="col-12">
                                                <label for="inputEmailAddress" class="form-label">Email ID</label>
                                                <input type="email" class="form-control" id="email" placeholder="Email Address">
                                            </div>
                                            <div class="col-12">
                                                <label for="inputChoosePassword" class="form-label">Password</label>
                                                <div class="input-group" id="show_hide_password">
                                                    <input type="password" class="form-control border-end-0" id="pass" value="" placeholder="Enter Password"> <a href="javascript:;" class="input-group-text bg-transparent"><i class='bx bx-hide'></i></a>
                                                </div>
                                            </div>
                                            <div class="col-md-6">

                                            </div>
                                            <div class="col-md-12" align="right">
                                                <a href="/Account/ForgotPassword">Forgot Password?</a>
                                            </div>
                                            <div class="col-12">
                                                <div class="d-grid">
                                                    <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                                                    <input type="hidden" id="hdnSiteErrorLogUrl" value='@Url.Action("LogClientError", "SPSiteError")' />
                                                    <input type="hidden" id="hfPostLoginRedirectUrl" value="@((ViewBag.PostLoginRedirectUrl ?? string.Empty).ToString())" />
                                                    <input id="hfAdminContactNo" value="" style="display:none" />
                                                    <button id="btnLogin" type="button" class="btn btn-primary"><i class="bx bxs-lock-open"></i>Login</button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!--end row-->
            </div>
        </div>
    </div>
    <!--end wrapper-->
    <div id="divImage" class="login-page-data-loader" aria-hidden="true">
        <div class="login-page-data-loader__content app-loader-card">
            <span class="app-loader-spinner login-page-data-loader__spinner" role="status" aria-label="Loading"></span>
        </div>
    </div>

    <div class="modal" id="OTPmodal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">One Time Password</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <h6>Please enter the one-time password sent to your device</h6><br />
                    <div class="otpcontainer">
                        <header>
                            <i class="bx bxs-check-shield"></i>
                        </header>
                        <h4>Enter OTP Code</h4>
                        <form action="#">
                            <div class="input-field">
                                <input id="otpdigit1" type="number" />
                                <input id="otpdigit2" type="number" disabled />
                                <input id="otpdigit3" type="number" disabled />
                                <input id="otpdigit4" type="number" disabled />
                            </div>
                        </form>
                        <h5 id="InvalidOTPMsg" style="color:red;display:none">Invalid OTP</h5>
                    </div>
                    <input id="hfSPNo" style="display:none" />
                    <input id="hfOTP" style="display:none" />
                    <input id="hfUserContactNo" style="display:none" />
                </div>
                <div class="modal-footer">
                    <button id="btnStop" style="display:none">Stop Timer</button>
                    <table id="tblTimer">
                        <tr>
                            <td><label id="lblMinutes" style="color:red;font-weight:bold">01</label><label style="color:red;font-weight:bold">:</label><label id="lblSeconds" style="color:red;font-weight:bold">60</label></td>
                        </tr>
                    </table>



                    <label id="lblOTPExpiredMsg" style="color:red;font-weight:bold;display:none">OTP Expired</label>

                    <h6 id="OTPSentMsg" style="color:green;display:none">OTP Sent</h6>
                    &nbsp;
                    <button id="btnLoginSpinner" class="btn btn-primary" type="button" disabled style="display:none">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span class="visually-hidden">Loading...</span>
                    </button>
                    &nbsp;
                    <button id="btnResendOTP" type="button" class="btn btn-primary" style="display:none">Resend OTP</button>
                    <button id="btnVerify" type="button" class="btn btn-primary">Verify</button>
                </div>
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/commonjs")
    <script src="~/Scripts/appjs/LoginOTP.js"></script>
    <!--Password show & hide js -->
    <script>
        function showLoginPageLoader() {
            $('#divImage').css('display', 'flex').attr('aria-hidden', 'false');
        }

        function hideLoginPageLoader() {
            $('#divImage').hide().attr('aria-hidden', 'true');
        }

        $(document).ready(function () {

          //GetAdminContact();
            var intervalID;
            var seconds = parseInt($("#lblSeconds").text());
            var minutes = parseInt($("#lblMinutes").text());
            var trustedDeviceStorageKey = 'trustedDeviceToken';
            var trustedDeviceExpiryKey = 'trustedDeviceExpiryUtc';

            // Function to call repeatedly
            function Timer() {

                if (minutes > 0) {
                    seconds = seconds - 1;
                    if (seconds == 0) {
                        seconds = parseInt("60");
                        minutes = minutes - 1;
                        $("#lblSeconds").text("");
                        $("#lblSeconds").text("60");
                        $("#lblMinutes").text("0" + minutes);
                    }

                    $("#lblSeconds").text("");
                    if (seconds < 10) {
                        $("#lblSeconds").text("0" + seconds);
                    }
                    else {
                        $("#lblSeconds").text(seconds);
                    }

                }
                else {

                    $('#btnStop').click();
                    $.post(
                        '/Account/UpdateOTPBlank?SPNo=' + $('#hfSPNo').val() + '&ContactNo=' + $('#hfUserContactNo').val(),
                        function (data) {

                        }
                    );

                }

            }

            // Function to start setInterval call
            function startTimer() {
                intervalID = setInterval(Timer, 1000);
            }

            var otpModalElement = document.getElementById('OTPmodal');
            var otpModalInstance = otpModalElement ? new bootstrap.Modal(otpModalElement) : null;

            function hideOtpModal() {
                if (otpModalInstance) {
                    otpModalInstance.hide();
                }
                else {
                    $('#OTPmodal').hide();
                }
            }

            function showOtpModal() {
                if (otpModalInstance) {
                    otpModalInstance.show();
                }
                else {
                    $('#OTPmodal').show();
                }
            }

            function buildDeviceFingerprint() {
                var parts = [
                    navigator.userAgent || '',
                    navigator.language || '',
                    navigator.platform || '',
                    (screen && screen.width ? screen.width : '') + 'x' + (screen && screen.height ? screen.height : ''),
                    screen && screen.colorDepth ? screen.colorDepth : '',
                    new Date().getTimezoneOffset()
                ];

                return parts.join('|');
            }

            function clearTrustedDeviceState() {
                try { localStorage.removeItem(trustedDeviceStorageKey); } catch (e) { }
                try { localStorage.removeItem(trustedDeviceExpiryKey); } catch (e) { }
            }

            function setTrustedDeviceState(token, expiryUtc) {
                if (!token) {
                    clearTrustedDeviceState();
                    return;
                }

                try { localStorage.setItem(trustedDeviceStorageKey, token); } catch (e) { }

                if (expiryUtc) {
                    try { localStorage.setItem(trustedDeviceExpiryKey, expiryUtc); } catch (e) { }
                }
            }

            function getTrustedDeviceToken() {
                var expiryUtc = '';

                try { expiryUtc = localStorage.getItem(trustedDeviceExpiryKey) || ''; } catch (e) { }

                if (expiryUtc) {
                    var expiryDate = new Date(expiryUtc);
                    if (!isNaN(expiryDate.getTime()) && expiryDate <= new Date()) {
                        clearTrustedDeviceState();
                        return '';
                    }
                }

                try { return localStorage.getItem(trustedDeviceStorageKey) || ''; } catch (e) { return ''; }
            }

            function resolvePostLoginRedirectUrl(serverRedirectUrl) {
                var redirectUrl = serverRedirectUrl || $('#hfPostLoginRedirectUrl').val() || '@Url.Action("Index", "SPDashboard")';
                return redirectUrl;
            }

            function detectPrivateMode(callback) {
                var completed = false;

                function finish(value) {
                    if (completed) {
                        return;
                    }

                    completed = true;
                    callback(value === true);
                }

                try {
                    var ua = (navigator.userAgent || '').toLowerCase();

                    if (window.webkitRequestFileSystem) {
                        window.webkitRequestFileSystem(window.TEMPORARY, 1, function () { finish(false); }, function () { finish(true); });
                        return;
                    }

                    if (ua.indexOf('firefox') >= 0 && window.indexedDB) {
                        try {
                            var db = indexedDB.open('trusted-device-check');
                            db.onerror = function () { finish(true); };
                            db.onsuccess = function () {
                                try {
                                    db.result.close();
                                    indexedDB.deleteDatabase('trusted-device-check');
                                } catch (e) { }
                                finish(false);
                            };
                            return;
                        }
                        catch (e) {
                            finish(true);
                            return;
                        }
                    }

                    if (navigator.storage && navigator.storage.estimate) {
                        navigator.storage.estimate().then(function (estimate) {
                            if (estimate && estimate.quota && estimate.quota < 120000000) {
                                finish(true);
                                return;
                            }

                            finish(false);
                        }, function () {
                            finish(false);
                        });
                        return;
                    }

                    finish(false);
                }
                catch (e) {
                    finish(false);
                }
            }

            $('#OTPmodal').on('hidden.bs.modal', function () {
                $('#btnLoginSpinner').hide();
                $('#InvalidOTPMsg').hide();
            });

            // Function to stop setInterval call
            function stopTimer() {

                clearInterval(intervalID);
                $('#tblTimer').css("display", "none");
                $('#OTPSentMsg').css('display', 'none');
                $('#lblOTPExpiredMsg').css("display", "block");
                $('#btnResendOTP').css('display', 'block');
                $('#btnVerify').css('display', 'none');

            }

            document.getElementById("btnStop").addEventListener("click", stopTimer);

			$("#show_hide_password a").on('click', function (event) {
				event.preventDefault();
				if ($('#show_hide_password input').attr("type") == "text") {
					$('#show_hide_password input').attr('type', 'password');
					$('#show_hide_password i').addClass("bx-hide");
					$('#show_hide_password i').removeClass("bx-show");
				} else if ($('#show_hide_password input').attr("type") == "password") {
					$('#show_hide_password input').attr('type', 'text');
					$('#show_hide_password i').removeClass("bx-hide");
					$('#show_hide_password i').addClass("bx-show");
				}
            });

            $('#pass').keypress(function (e) {
                if (e.which == 13) {
                    $('#btnLogin').click();
                    return false;
                }
            });

            $('#btnLogin').click(function () {

                showLoginPageLoader();

                if ($('#email').val() != "" && $('#pass').val() != "") {
                    detectPrivateMode(function (isPrivateMode) {
                        $.post('/Account/CheckLoginAndSendOTP', {
                            email: $('#email').val(),
                            pass: $('#pass').val(),
                            adminContactNo: $('#hfAdminContactNo').val(),
                            trustedDeviceToken: getTrustedDeviceToken(),
                            deviceFingerprint: buildDeviceFingerprint(),
                            isPrivateMode: isPrivateMode
                        }, function (data) {
                            if (data && data.ClearTrustedDeviceState) {
                                clearTrustedDeviceState();
                            }

                            if (data && data.No != null) {
                                if (data.RequireOtpVerification) {
                                    hideLoginPageLoader();
                                    showOtpModal();
                                    $('#hfSPNo').val(data.No);
                                    $('#hfUserContactNo').val(data.Phone_No_2);
                                    startTimer();
                                }
                                else {
                                    if (data.TrustedDeviceToken) {
                                        setTrustedDeviceState(data.TrustedDeviceToken, data.TrustedDeviceExpiresUtc);
                                    }

                                    hideLoginPageLoader();
                                    if (data.Status == "Inactive") {
                                        var msg = "User is Inactive";
                                        ShowActionMsg(msg);
                                    }
                                    else {
                                        window.location.replace(resolvePostLoginRedirectUrl(data.RedirectUrl));
                                    }
                                }
                            }
                            else {
                                hideLoginPageLoader();
                                var msg = "Please Enter Correct Email ID and Password.";
                                ShowErrorMsg(msg);
                            }
                        }).fail(function () {
                            hideLoginPageLoader();
                            ShowErrorMsg('Unable to process login right now.');
                        });
                    });
                }
                else {
                    hideLoginPageLoader();
                    var msg = "Please Enter Email ID and Password.";
                    ShowErrorMsg(msg);
                }
            });

            $('#btnVerify').click(function () {

                $('#btnLoginSpinner').show();
                var OTPInput = $('#otpdigit1').val() + $('#otpdigit2').val() + $('#otpdigit3').val() + $('#otpdigit4').val();

                detectPrivateMode(function (isPrivateMode) {
                    $.post('/Account/CheckLogin', {
                        SPNo: $('#hfSPNo').val(),
                        OTP: OTPInput,
                        ContactNo: $('#hfUserContactNo').val(),
                        deviceFingerprint: buildDeviceFingerprint(),
                        isPrivateMode: isPrivateMode
                    }, function (data) {
                        if (data && data.ClearTrustedDeviceState) {
                            clearTrustedDeviceState();
                        }

                        if (data && data.IsSuccess) {
                            if (data.TrustedDeviceToken) {
                                setTrustedDeviceState(data.TrustedDeviceToken, data.TrustedDeviceExpiresUtc);
                            }

                            $('#btnLoginSpinner').hide();
                            window.location.replace(resolvePostLoginRedirectUrl(data.RedirectUrl));
                        }
                        else {
                            hideLoginPageLoader();
                            $('#btnLoginSpinner').hide();

                            $('#InvalidOTPMsg').css('display', 'block');
                            $('#otpdigit1,#otpdigit2,#otpdigit3,#otpdigit4').val("");
                            $('#otpdigit1,#otpdigit2,#otpdigit3,#otpdigit4').removeAttr("value");
                            $('#otpdigit1').focus();
                        }
                    }).fail(function () {
                        $('#btnLoginSpinner').hide();
                        ShowErrorMsg('Unable to verify OTP right now.');
                    });
                });
            });

            $('#btnResendOTP').click(function () {

                $('#btnLoginSpinner').show();

                $.get('/Account/ResendOTP?email=' + $('#email').val() + '&pass=' + $('#pass').val() +
                    '&adminContactNo=' + $('#hfAdminContactNo').val(), function (data) {
                        if (data)
                        {
                            $('#btnLoginSpinner').hide();
                            $('#btnResendOTP').css('display', 'none');
                            $('#btnVerify').css('display', 'block');
                            $('#InvalidOTPMsg').css('display', 'none');
                            $('#lblOTPExpiredMsg').css('display', 'none');
                            $('#OTPSentMsg').css('display', 'block');
                            $('#tblTimer').css('display', 'block');
                            $('#lblMinutes').text("01");
                            minutes = 1;
                            seconds = 60;
                            showOtpModal();
                            startTimer();
                        }
                        else {
                            $('#btnLoginSpinner').hide();

                        }
                });
            });
            //OTP functionality on Login End*/
        });

        function GetAdminContact() {

            var apiUrl = $('#getServiceApiUrl').val() + 'Salesperson/'.

            $.get(apiUrl + 'GetAdminContactNo', function (data) {

                if (data != "") {

                    $('#hfAdminContactNo').val(data);
                }

            });

        }
        function ShowActionMsg(actionMsg) {
            Lobibox.notify('error', {
                pauseDelayOnHover: true,
                size: 'mini',
                rounded: true,
                icon: 'bx bx-check-circle',
                delayIndicator: false,
                continueDelayOnInactiveTab: false,
                position: 'top right',
                msg: actionMsg
            });
        }

        function ShowErrorMsg(errMsg) {

            Lobibox.notify('error', {
                pauseDelayOnHover: true,
                size: 'mini',
                rounded: true,
                delayIndicator: false,
                icon: 'bx bx-x-circle',
                continueDelayOnInactiveTab: false,
                position: 'top right',
                msg: errMsg
            });
        }

        (function () {
            var logUrl = $('#hdnSiteErrorLogUrl').val();
            var sentErrors = {};

            function shouldSkip(url) {
                if (!url) return false;
                var normalizedUrl = (url + '').toLowerCase();
                return normalizedUrl.indexOf('/spsiteerror/logclienterror') >= 0 || normalizedUrl.indexOf('/spsiteerror/logerror') >= 0;
            }

            function sendSiteError(payload) {
                try {
                    if (!logUrl || !payload || shouldSkip(payload.Web_URL)) return;

                    payload.Error_Code = payload.Error_Code || 'CLIENT_ERR';
                    payload.Exception_Message = payload.Exception_Message || 'Unhandled login page error';
                    payload.Exception_Stack_Trace = payload.Exception_Stack_Trace || '';
                    payload.Source = payload.Source || 'Login';
                    payload.IP_Address = payload.IP_Address || '';
                    payload.Browser = payload.Browser || navigator.userAgent || '';
                    payload.Description = payload.Description || 'Severity: High';
                    payload.Web_URL = payload.Web_URL || window.location.pathname + window.location.search;

                    var errorKey = [payload.Error_Code, payload.Exception_Message, payload.Web_URL].join('|');
                    if (sentErrors[errorKey]) return;
                    sentErrors[errorKey] = true;

                    $.ajax({
                        url: logUrl,
                        type: 'POST',
                        contentType: 'application/json; charset=utf-8',
                        data: JSON.stringify(payload)
                    });
                } catch (e) { }
            }

            var originalShowErrorMsg = window.ShowErrorMsg;
            window.ShowErrorMsg = function (errMsg) {
                try {
                    if (errMsg) {
                        sendSiteError({
                            Error_Code: 'LOGIN_ERR',
                            Exception_Message: errMsg,
                            Source: 'Login Action',
                            Description: 'Severity: High | Action: Login',
                            Web_URL: window.location.pathname + window.location.search
                        });
                    }
                } catch (e) { }

                return originalShowErrorMsg.apply(this, arguments);
            };

            window.addEventListener('error', function (event) {
                sendSiteError({
                    Error_Code: 'JS_ERR',
                    Exception_Message: event && event.message ? event.message : 'JavaScript error',
                    Exception_Stack_Trace: event && event.error && event.error.stack ? event.error.stack : '',
                    Source: 'Login Script',
                    Description: 'Severity: High',
                    Web_URL: window.location.pathname + window.location.search
                });
            }, true);

            window.addEventListener('unhandledrejection', function (event) {
                var reason = event ? event.reason : null;
                sendSiteError({
                    Error_Code: 'PROMISE_ERR',
                    Exception_Message: reason && reason.message ? reason.message : 'Unhandled promise rejection',
                    Exception_Stack_Trace: reason && reason.stack ? reason.stack : '',
                    Source: 'Login Promise',
                    Description: 'Severity: High',
                    Web_URL: window.location.pathname + window.location.search
                });
            });

            $(document).ajaxError(function (event, jqxhr, settings, thrownError) {
                var failedUrl = settings && settings.url ? settings.url : window.location.pathname;
                if (shouldSkip(failedUrl)) return;

                sendSiteError({
                    Error_Code: 'AJAX_ERR',
                    Exception_Message: thrownError || ('AJAX request failed with status ' + (jqxhr ? jqxhr.status : '0')),
                    Exception_Stack_Trace: jqxhr && jqxhr.responseText ? jqxhr.responseText.substring(0, 1500) : '',
                    Source: 'Login AJAX',
                    Description: 'Severity: High | Status: ' + (jqxhr ? jqxhr.status : '0'),
                    Web_URL: failedUrl
                });
            });
        })();
    </script>
</body>
</html>
