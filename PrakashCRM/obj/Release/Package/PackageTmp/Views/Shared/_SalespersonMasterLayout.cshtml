        <script>
            window.pageDataLoader = (function () {
                var activeCount = 0;

                function setVisible(isVisible) {
                    var loader = document.getElementById('globalPageDataLoader');
                    if (!loader) {
                        return;
                    }

                    loader.style.display = isVisible ? 'flex' : 'none';
                    loader.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
                }

                return {
                    show: function () {
                        activeCount += 1;
                        setVisible(true);
                    },
                    hide: function (force) {
                        activeCount = force ? 0 : Math.max(0, activeCount - 1);
                        if (activeCount === 0) {
                            setVisible(false);
                        }
                    },
                    reset: function () {
                        activeCount = 0;
                        setVisible(false);
                    }
                };
            })();

            window.showPageDataLoader = function () {
                if (window.pageDataLoader) {
                    window.pageDataLoader.show();
                }
            };

            window.hidePageDataLoader = function (force) {
                if (window.pageDataLoader) {
                    window.pageDataLoader.hide(force === true);
                }
            };

            (function () {
                function isInternalNavigationLink(anchor) {
                    if (!anchor || !anchor.href) {
                        return false;
                    }

                    if (anchor.hasAttribute('download') || anchor.target === '_blank') {
                        return false;
                    }

                    var rawHref = anchor.getAttribute('href') || '';
                    if (!rawHref || rawHref === '#' || rawHref.indexOf('javascript:') === 0 || rawHref.indexOf('mailto:') === 0 || rawHref.indexOf('tel:') === 0) {
                        return false;
                    }

                    return anchor.origin === window.location.origin;
                }

                function shouldSkipFormLoader(form) {
                    if (!form) {
                        return true;
                    }

                    var target = (form.getAttribute('target') || '').toLowerCase();
                    return target === '_blank';
                }

                function bindGlobalLoader() {
                    document.addEventListener('click', function (event) {
                        if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                            return;
                        }

                        var anchor = event.target.closest('a');
                        if (!isInternalNavigationLink(anchor)) {
                            return;
                        }

                        //window.showPageDataLoader();
                    });

                    document.addEventListener('submit', function (event) {
                        var form = event.target;
                        if (event.defaultPrevented || shouldSkipFormLoader(form)) {
                            return;
                        }

                        window.showPageDataLoader();
                    });

                    window.addEventListener('pageshow', function () {
                        window.hidePageDataLoader();
                    });

                    window.addEventListener('load', function () {
                        window.hidePageDataLoader();
                    });

                    window.showPageDataLoader();
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', bindGlobalLoader);
                }
                else {
                    bindGlobalLoader();
                }
            })();
        </script>
