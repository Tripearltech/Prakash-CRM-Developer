@using Newtonsoft.Json
@using PrakashCRM.Data.Models
@using System.Configuration
@using System.Linq
@using System.Net.Http
@using System.Net.Http.Headers
@{
    // Session check at layout level
    if (Session["loggedInUserEmail"] == null)
    {
        var loginUrl = Url.Action("Login", "Account");
        var currentRequestUrl = Request == null ? string.Empty : Request.RawUrl;
        if (!string.IsNullOrWhiteSpace(currentRequestUrl))
        {
            loginUrl += "?returnUrl=" + System.Web.HttpUtility.UrlEncode(currentRequestUrl);
        }

        Response.Redirect(loginUrl);
    }
}
<style>
    .notification-preview-empty,
    .notification-page-empty {
        color: #6c757d;
        padding: 1rem;
        text-align: center;
    }

    .global-page-data-loader {
        position: absolute;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(2px);
        z-index: 1000;
    }

    .global-page-data-loader__content {
        min-width: 140px;
    }

    .global-page-data-loader__spinner {
        width: 3.5rem;
        height: 3.5rem;
        border-width: 0.4rem;
    }

    .notification-item-card.notification-is-unread {
        background: #fff9ef;
    }

    .notification-item-card .msg-info {
        margin-bottom: 0;
        white-space: normal;
    }

    .notification-filter-chip.active {
        background: #212529;
        border-color: #212529;
        color: #fff;
    }

    #headerNotificationsList {
        max-height: 420px;
        overflow-y: auto;
    }
</style>
