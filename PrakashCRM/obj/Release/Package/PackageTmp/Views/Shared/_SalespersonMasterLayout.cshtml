    <script>
    function readJsonScript(id, fallback) {
        var el = document.getElementById(id);
        if (!el) return fallback;
        var txt = (el.textContent || el.innerText || '').trim();
        if (!txt) return fallback;
        try { return JSON.parse(txt); } catch (e) { return fallback; }
    }

    // expose as globals (used by menu rendering and other pages like SPMenu.js)
    window.roleMenu = readJsonScript('roleMenuJson', null);
    window.menuUrlMap = readJsonScript('menuUrlMapJson', {});
    window.menuIconMap = readJsonScript('menuIconMapJson', {});
    window.menuSectionMap = readJsonScript('menuSectionMapJson', {});

    var roleMenu = window.roleMenu;
    var menuUrlMap = window.menuUrlMap;
    var menuIconMap = window.menuIconMap;
    var menuSectionMap = window.menuSectionMap;

    function hasAnyRights(p) {
        if (!p) return true; // fail-open if payload doesn't carry permissions
        return !!(p.read || p.create || p.update || p.delete || p.Read || p.Create || p.Update || p.Delete);
    }

    function getChildPerms(child) {
        if (!child) return null;
        var p = child.permissions || child.Permissions || null;
        if (!p) return null;
        // normalize in case payload uses PascalCase
        return {
            read: !!(p.read || p.Read || p.view || p.View || p.View_Rights || p.Read_Rights || p.Full_Rights),
            create: !!(p.create || p.Create || p.add || p.Add || p.Add_Rights || p.Insert_Rights || p.Full_Rights),
            update: !!(p.update || p.Update || p.edit || p.Edit || p.Edit_Rights || p.Modify_Rights || p.Full_Rights),
            delete: !!(p.delete || p.Delete || p.Delete_Rights || p.Remove_Rights || p.Full_Rights)
        };
    }

    $(document).ready(function () {

        if (!roleMenu || !roleMenu.roles) return;

        let menuHtml = '';
        let renderedSections = {};

        roleMenu.roles.forEach(role => {

            role.menus.forEach(menu => {

                // normalize children: ignore blank/invalid child items
                const children = (menu.children && Array.isArray(menu.children))
                    ? menu.children.filter(c => c && c.menuName && c.menuName.toString().trim().length > 0)
                    : [];

                // Only render children that the user can at least VIEW (or has any rights for).
                const visibleChildren = (children.length > 0)
                    ? children.filter(c => hasAnyRights(getChildPerms(c)))
                    : [];

                let section = null;

                if (visibleChildren.length > 0) {
                    for (let i = 0; i < visibleChildren.length; i++) {
                        let childName = visibleChildren[i].menuName;
                        if (menuSectionMap[childName]) {
                            section = menuSectionMap[childName];
                            break;
                        }
                    }
                }

                if (!section) {
                    section = menuSectionMap[menu.menuName];
                }

                if (section && !renderedSections[section]) {
                    menuHtml += `<li class="menu-label">${section}</li>`;
                    renderedSections[section] = true;
                }

                let icon = menuIconMap[menu.menuName] || 'bx bx-folder';

                // If this is a single/leaf menu (no children) -> render as direct link (no dropdown/arrow)
                if (children.length === 0) {

                    // Enforce view for leaf menus as well (e.g., Dashboard).
                    try {
                        if (window.PermissionService && typeof window.PermissionService.getForMenuName === 'function') {
                            var lp = window.PermissionService.getForMenuName(menu.menuName);
                            if (lp && lp.resolved === true) {
                                var any = !!(lp.read || lp.create || lp.update || lp.delete);
                                if (!any) return;
                            }
                        }
                    } catch (e) { }

                    let url = '#';

                    // Prefer explicit mapping by name (covers Dashboard etc.)
                    if (menuUrlMap && menuUrlMap[menu.menuName]) {
                        url = menuUrlMap[menu.menuName];
                    }
                    else if (menu.action === 'Navigation') {
                        // keep fallback behavior
                        url = '#';
                    }
                    else if (menu.controller && menu.action) {
                        url = '/' + menu.controller + '/' + menu.action;
                    }

                    if (!url || url === '#') url = 'javascript:;';

                    menuHtml += `
                        <li>
                            <a href="${url}">
                                <div class="parent-icon">
                                    <i class="${icon}"></i>
                                </div>
                                <div class="menu-title">${menu.menuName}</div>
                            </a>
                        </li>
                    `;

                    return;
                }

                // Parent menus with children: if user cannot see any child, skip the parent.
                if (visibleChildren.length === 0) {
                    return;
                }

                // If parent has exactly one visible child and the child's name matches the parent,
                // render a single direct-link item (prevents showing Dashboard twice).
                const collapseSingleSameChild = (function () {
                    if (visibleChildren.length !== 1) return false;
                    const child = visibleChildren[0];
                    const parentName = (menu && menu.menuName) ? menu.menuName.toString().trim().toLowerCase() : '';
                    const childName = (child && child.menuName) ? child.menuName.toString().trim().toLowerCase() : '';
                    if (!parentName || !childName) return false;
                    return parentName === childName;
                })();

                if (collapseSingleSameChild) {
                    const child = visibleChildren[0];
                    let url = '#';

                    // Prefer explicit mapping by name
                    if (menuUrlMap && menuUrlMap[child.menuName]) {
                        url = menuUrlMap[child.menuName];
                    }
                    else if (child.controller && child.action) {
                        url = '/' + child.controller + '/' + child.action;
                    }
                    else if (menuUrlMap && menuUrlMap[menu.menuName]) {
                        url = menuUrlMap[menu.menuName];
                    }
                    else if (menu.controller && menu.action) {
                        url = '/' + menu.controller + '/' + menu.action;
                    }

                    if (!url || url === '#') url = 'javascript:;';

                    menuHtml += `
                        <li>
                            <a href="${url}">
                                <div class="parent-icon">
                                    <i class="${icon}"></i>
                                </div>
                                <div class="menu-title">${menu.menuName}</div>
                            </a>
                        </li>
                    `;

                    return;
                }

                // Parent menus with children -> keep dropdown
                menuHtml += `
                    <li>
                        <a href="javascript:;" class="has-arrow">
                            <div class="parent-icon">
                                <i class="${icon}"></i>
                            </div>
                            <div class="menu-title">${menu.menuName}</div>
                        </a>
                        <ul>
                `;

                // 🔹 Child Menus
 if (visibleChildren.length > 0) {
                 visibleChildren.forEach(child => {

                     // READ/VIEW permission check (show if any rights exist)
                     var perms = getChildPerms(child);
                     if (!hasAnyRights(perms)) return;
                     {

                         let url = '#';

                         // Prefer explicit mapping by name
                         if (menuUrlMap && menuUrlMap[child.menuName]) {
                             url = menuUrlMap[child.menuName];
                         }
                         else if (child.action === 'Navigation') {
                             url = '#';
                         }
                         else {
                             // fallback (future-safe)
                             url = '/' + child.controller + '/' + child.action;
                         }


                         menuHtml += `
                         <li>
                             <a href="${url}">
                                 <i class="bx bx-right-arrow-alt"></i>
                                 ${child.menuName}
                             </a>
                         </li>
                     `;
                     }
                 });
             }

             menuHtml += `
                 </ul>
             </li>
         `;
         });
     });
        $('#dynamicMenu').html(menuHtml);
        $('#dynamicMenu').metisMenu();

        // ---- DEFAULT PAGE-LEVEL PERMISSIONS (create/update/delete/view) ----
        try {
            if (window.PermissionService && typeof window.PermissionService.getForCurrentPage === 'function') {
                var fallbackMenuName = null;
                try {
                    fallbackMenuName = window.__permFallbackMenuName || null;
                } catch (e) { fallbackMenuName = null; }

                var perms = window.PermissionService.getForCurrentPage(fallbackMenuName);
                window.currentPagePerms = perms;

                // Install DOM guards (e.g., disable edit icons when no update rights)
                try {
                    if (typeof window.PermissionService.installDomGuards === 'function') {
                        window.PermissionService.installDomGuards(perms);
                    }
                } catch (e) { }

                // ---- DASHBOARD-SPECIFIC (STRICT): enable only when permission exists ----
                // If permissions are not resolved, default DISABLE these create actions.
                try {
                    function disableButton($btn) {
                        if (!$btn || !$btn.length) return;
                        $btn.prop('disabled', true).css({ 'pointer-events': 'none', 'opacity': 0.55 });
                    }

                    function enableButton($btn) {
                        if (!$btn || !$btn.length) return;
                        $btn.prop('disabled', false).css({ 'pointer-events': '', 'opacity': '' });
                    }

                    // Market Update actions live on Dashboard => gate by current page create/update.
                    var dashCanCreate = !!(perms && perms.resolved === true && perms.create);
                    var dashCanSave = !!(perms && perms.resolved === true && (perms.create || perms.update));

                    var $muAdd = $('#btnAddMUpdate');
                    if ($muAdd.length && !dashCanCreate) disableButton($muAdd);
                    var $muSave = $('#modalMarketUpdate #btnSave');
                    if ($muSave.length && !dashCanSave) disableButton($muSave);

                    // Daily Visit buttons navigate to another page => gate by that target page create right.
                    var $dvCreate = $('#btnCreateDV');
                    var $dvCreate1 = $('#btnCreateDV1');
                    if ($dvCreate.length || $dvCreate1.length) {
                        var dvCanCreate = false;
                        function permBool(v) {
                            if (v === true || v === false) return v;
                            if (v === null || v === undefined) return false;
                            if (typeof v === 'number') return v !== 0;
                            if (typeof v === 'string') {
                                var s = v.trim().toLowerCase();
                                if (!s) return false;
                                if (s === 'true' || s === '1' || s === 'yes' || s === 'y') return true;
                                if (s === 'false' || s === '0' || s === 'no' || s === 'n') return false;
                            }
                            return !!v;
                        }
                        if (window.PermissionService) {
                            // Prefer the actual create page
                            if (typeof window.PermissionService.getForControllerAction === 'function') {
                                var dvPerms = window.PermissionService.getForControllerAction('SPVisitEntry', 'DailyVisit');
                                dvCanCreate = !!(dvPerms && dvPerms.resolved === true && dvPerms.create);

                                // Fallback: some payloads only include the list route
                                if (!dvCanCreate) {
                                    var dvListPerms = window.PermissionService.getForControllerAction('SPVisitEntry', 'DailyVisitList');
                                    dvCanCreate = !!(dvListPerms && dvListPerms.resolved === true && dvListPerms.create);
                                }
                            }

                            // Fallback by menu name mapping (if controller/action isn't present)
                            if (!dvCanCreate && typeof window.PermissionService.getForMenuName === 'function') {
                                var byName = window.PermissionService.getForMenuName('Daily Visit List');
                                dvCanCreate = !!(byName && byName.resolved === true && byName.create);
                            }

                            if (!dvCanCreate && typeof window.PermissionService.getForMenuName === 'function') {
                                var byName2 = window.PermissionService.getForMenuName('Daily Visit');
                                dvCanCreate = !!(byName2 && byName2.resolved === true && byName2.create);
                            }

                            // Last-resort fallback: menu name varies across environments.
                            // If we still can't resolve, scan payload for any menu containing 'Daily Visit'.
                            if (!dvCanCreate && window.roleMenu && Array.isArray(window.roleMenu.roles)) {
                                try {
                                    window.roleMenu.roles.forEach(function (r) {
                                        (r.menus || []).forEach(function (m) {
                                            (m.children || []).forEach(function (c) {
                                                var name = (c && c.menuName) ? c.menuName.toString() : '';
                                                if (!name) return;
                                                if (name.toLowerCase().indexOf('daily visit') < 0) return;
                                                var p = c.permissions || c.Permissions || c || {};
                                                var hasFull = permBool(p.Full_Rights) || permBool(p.full) || permBool(p.Full) || permBool(p.fullRights);
                                                var canCreate = permBool(p.create) || permBool(p.Create) || permBool(p.add) || permBool(p.Add) || permBool(p.Add_Rights) || permBool(p.Insert_Rights) || hasFull;
                                                if (canCreate) dvCanCreate = true;
                                            });
                                        });
                                    });
                                } catch (e) { }
                            }
                        }

                        if ($dvCreate.length) (dvCanCreate ? enableButton($dvCreate) : disableButton($dvCreate));
                        if ($dvCreate1.length) (dvCanCreate ? enableButton($dvCreate1) : disableButton($dvCreate1));
                    }
                } catch (e) { }

                var resolved = (perms && typeof perms.resolved === 'boolean') ? perms.resolved : true;

                // IMPORTANT:
                // - If we can resolve rights => enforce strictly.
                // - If we cannot resolve rights => do not force-disable controls (avoid false negatives).
                var allowCreate = !!(perms && resolved === true && perms.create);
                var allowUpdate = !!(perms && resolved === true && perms.update);
                var allowDelete = !!(perms && resolved === true && perms.delete);
                var allowSave = !!(perms && resolved === true && (perms.create || perms.update));

                if (resolved === true) {
                    var hasAny = !!(perms && (perms.read || perms.create || perms.update || perms.delete));
                    if (!hasAny) {
                        // If the user has no rights at all for this page, redirect to dashboard.
                        var dash = (window.menuUrlMap && window.menuUrlMap['Dashboard']) ? window.menuUrlMap['Dashboard'] : '/SPDashboard/Index';
                        try {
                            if (window.Lobibox && Lobibox.notify) {
                                Lobibox.notify('error', {
                                    pauseDelayOnHover: true,
                                    size: 'mini',
                                    rounded: true,
                                    delayIndicator: false,
                                    icon: 'bx bx-x-circle',
                                    continueDelayOnInactiveTab: false,
                                    position: 'top right',
                                    msg: 'You do not have View rights for this page'
                                });
                            }
                        } catch (e) { }
                        window.location.href = dash;
                        return;
                    }
                }

                function shouldSkipId(idLower) {
                    // Avoid touching spinners or purely UI helpers.
                    return idLower.endsWith('spinner') || idLower.indexOf('search') >= 0 || idLower.indexOf('export') >= 0 || idLower.indexOf('clear') >= 0;
                }

                function applyToElements(matchFn, allowed, $scope) {
                    var $targets = $scope && $scope.length
                        ? $scope.find('button[id], button[onclick], a[id], a[onclick], input[type=button][id], input[type=button][onclick], input[type=submit][id], input[type=submit][onclick]')
                            .addBack('button[id], button[onclick], a[id], a[onclick], input[type=button][id], input[type=button][onclick], input[type=submit][id], input[type=submit][onclick]')
                        : $('button[id], button[onclick], a[id], a[onclick], input[type=button][id], input[type=button][onclick], input[type=submit][id], input[type=submit][onclick]');

                    $targets.each(function () {
                        var idLower = ((this.id || '') + '').toLowerCase();
                        var onclickLower = '';
                        try {
                            onclickLower = ((this.getAttribute && (this.getAttribute('onclick') || '')) || '').toString().toLowerCase();
                        } catch (e) { }

                        if (idLower && shouldSkipId(idLower)) return;
                        if (!matchFn(idLower, this, onclickLower)) return;

                        if (window.ElementStateService && typeof window.ElementStateService.setEnabled === 'function') {
                            window.ElementStateService.setEnabled(this, !!allowed, { disabledOpacity: 0.55 });
                        } else if (!allowed) {
                            // fallback
                            $(this).css({ 'pointer-events': 'none', 'opacity': 0.55 });
                            if ('disabled' in this) this.disabled = true;
                        }
                    });
                }

                function applyCrudDisables($scope) {
                    // CREATE
                    applyToElements(function (idLower, el, onclickLower) {
                        // These buttons are permissioned by their target page (Daily Visit), not the current page.
                        if (idLower === 'btncreatedv' || idLower === 'btncreatedv1') return false;
                        return (idLower.indexOf('add') >= 0 || idLower.indexOf('new') >= 0 || idLower.indexOf('create') >= 0 || idLower.indexOf('insert') >= 0) ||
                            (onclickLower.indexOf('add') >= 0 || onclickLower.indexOf('new') >= 0 || onclickLower.indexOf('create') >= 0 || onclickLower.indexOf('insert') >= 0);
                    }, allowCreate, $scope);

                    // UPDATE
                    applyToElements(function (idLower, el, onclickLower) {
                        // Avoid misclassifying CREATE buttons like 'btnAddMUpdate' (contains 'update').
                        if (idLower.indexOf('add') >= 0 || idLower.indexOf('new') >= 0 || idLower.indexOf('create') >= 0 || idLower.indexOf('insert') >= 0) {
                            return false;
                        }
                        return (idLower.indexOf('edit') >= 0 || idLower.indexOf('update') >= 0) ||
                            (onclickLower.indexOf('edit') >= 0 || onclickLower.indexOf('update') >= 0);
                    }, allowUpdate, $scope);

                    // DELETE
                    applyToElements(function (idLower, el, onclickLower) {
                        if (idLower.indexOf('delete') >= 0 || idLower.indexOf('remove') >= 0) return true;
                        return onclickLower.indexOf('delete') >= 0 || onclickLower.indexOf('remove') >= 0;
                    }, allowDelete, $scope);

                    // SAVE
                    applyToElements(function (idLower, el, onclickLower) {
                        return idLower.indexOf('save') >= 0 || onclickLower.indexOf('save') >= 0;
                    }, allowSave, $scope);
                }

                // Apply once for current DOM (only when permission resolution succeeded)
                if (resolved === true) {
                    applyCrudDisables(null);
                }

                // Re-apply for dynamically injected controls (AJAX/partials/modals)
                try {
                    var _permDebounce = null;
                    var observer = new MutationObserver(function (mutations) {
                        if (_permDebounce) clearTimeout(_permDebounce);
                        _permDebounce = setTimeout(function () {
                            // Apply to whole document (safe), but still reasonably cheap due to ID filtering.
                            if (resolved === true) {
                                applyCrudDisables(null);
                            }
                        }, 50);
                    });
                    if (document && document.body) {
                        observer.observe(document.body, { childList: true, subtree: true });
                    }
                } catch (e) { }
            }
        } catch (e) {
            // fail-open
        }
    });
    </script>

    <script>
        (function () {
            var logUrl = $('#hdnSiteErrorLogUrl').val();
            var isLoggingSiteError = false;
            var sentErrors = {};
            var lastActionContext = null;

            function shouldSkip(url) {
                if (!url) return false;
                var normalizedUrl = (url + '').toLowerCase();
                return normalizedUrl.indexOf('/spsiteerror/logclienterror') >= 0 || normalizedUrl.indexOf('/spsiteerror/logerror') >= 0;
            }

            function buildKey(payload) {
                return [payload.Error_Code, payload.Source, payload.Exception_Message, payload.Web_URL].join('|');
            }

            function getRecentActionContext() {
                if (!lastActionContext || !lastActionContext.timestamp) return null;
                if ((new Date().getTime() - lastActionContext.timestamp) > 15000) return null;
                return lastActionContext;
            }

            function markActionContext(actionName, triggerText) {
                lastActionContext = {
                    actionName: actionName || 'Action',
                    triggerText: triggerText || '',
                    timestamp: new Date().getTime()
                };
            }

            function detectActionName($element) {
                if (!$element || !$element.length) return '';

                var id = (($element.attr('id') || '') + '').toLowerCase();
                var cls = (($element.attr('class') || '') + '').toLowerCase();
                var text = (($element.text() || $element.val() || '') + '').toLowerCase().trim();
                var combined = [id, cls, text].join(' ');

                if (combined.indexOf('save') >= 0) return 'Save';
                if (combined.indexOf('update') >= 0) return 'Update';
                if (combined.indexOf('edit') >= 0) return 'Edit';
                if (combined.indexOf('submit') >= 0) return 'Submit';

                return '';
            }

            function hookShowErrMsg() {
                try {
                    if (typeof window.ShowErrMsg !== 'function') return;
                    if (window.ShowErrMsg.__siteErrorWrapped === true) return;

                    var originalShowErrMsg = window.ShowErrMsg;
                    var wrappedShowErrMsg = function (errMsg) {
                        try {
                            var actionContext = getRecentActionContext();
                            if (actionContext && errMsg) {
                                sendSiteError({
                                    Error_Code: 'ACTION_ERR',
                                    Exception_Message: errMsg,
                                    Exception_Stack_Trace: actionContext.triggerText || '',
                                    Source: 'Client ' + actionContext.actionName,
                                    Description: 'Severity: High | Action: ' + actionContext.actionName,
                                    Web_URL: window.location.pathname + window.location.search
                                });
                            }
                        } catch (e) { }

                        return originalShowErrMsg.apply(this, arguments);
                    };

                    wrappedShowErrMsg.__siteErrorWrapped = true;
                    wrappedShowErrMsg.__original = originalShowErrMsg;
                    window.ShowErrMsg = wrappedShowErrMsg;
                } catch (e) { }
            }

            function hookShowErrorMsg() {
                try {
                    if (typeof window.ShowErrorMsg !== 'function') return;
                    if (window.ShowErrorMsg.__siteErrorWrapped === true) return;

                    var originalShowErrorMsg = window.ShowErrorMsg;
                    var wrappedShowErrorMsg = function (errMsg) {
                        try {
                            var actionContext = getRecentActionContext();
                            if (actionContext && errMsg) {
                                sendSiteError({
                                    Error_Code: 'ACTION_ERR',
                                    Exception_Message: errMsg,
                                    Exception_Stack_Trace: actionContext.triggerText || '',
                                    Source: 'Client ' + actionContext.actionName,
                                    Description: 'Severity: High | Action: ' + actionContext.actionName,
                                    Web_URL: window.location.pathname + window.location.search
                                });
                            }
                        } catch (e) { }

                        return originalShowErrorMsg.apply(this, arguments);
                    };

                    wrappedShowErrorMsg.__siteErrorWrapped = true;
                    wrappedShowErrorMsg.__original = originalShowErrorMsg;
                    window.ShowErrorMsg = wrappedShowErrorMsg;
                } catch (e) { }
            }

            function captureMessageFromDom() {
                try {
                    var actionContext = getRecentActionContext();
                    if (!actionContext) return;

                    var selectors = [
                        '#lblMsg',
                        '[id$="lblMsg"]',
                        '#modalErrDetails',
                        '#InvalidOTPMsg',
                        '.validation-summary-errors',
                        '.field-validation-error'
                    ];

                    for (var i = 0; i < selectors.length; i++) {
                        var $elements = $(selectors[i]);
                        for (var j = 0; j < $elements.length; j++) {
                            var $element = $($elements[j]);
                            var text = ($element.text() || '').trim();
                            if (!text) continue;
                            if (!$element.is(':visible') && selectors[i] !== '.validation-summary-errors' && selectors[i] !== '.field-validation-error') continue;

                            sendSiteError({
                                Error_Code: 'ACTION_ERR',
                                Exception_Message: text,
                                Exception_Stack_Trace: actionContext.triggerText || '',
                                Source: 'Client ' + actionContext.actionName,
                                Description: 'Severity: High | Action: ' + actionContext.actionName,
                                Web_URL: window.location.pathname + window.location.search
                            });
                            return;
                        }
                    }
                } catch (e) { }
            }

            function sendSiteError(payload) {
                try {
                    if (!logUrl || isLoggingSiteError) return;
                    if (!payload || shouldSkip(payload.Web_URL)) return;

                    payload.Error_Code = payload.Error_Code || 'CLIENT_ERR';
                    payload.Exception_Message = payload.Exception_Message || 'Unhandled client error';
                    payload.Exception_Stack_Trace = payload.Exception_Stack_Trace || '';
                    payload.Source = payload.Source || 'Client';
                    payload.IP_Address = payload.IP_Address || '';
                    payload.Browser = payload.Browser || navigator.userAgent || '';
                    payload.Description = payload.Description || 'Severity: High';
                    payload.Web_URL = payload.Web_URL || window.location.pathname + window.location.search;

                    var errorKey = buildKey(payload);
                    if (sentErrors[errorKey]) return;
                    sentErrors[errorKey] = true;

                    isLoggingSiteError = true;

                    $.ajax({
                        url: logUrl,
                        type: 'POST',
                        contentType: 'application/json; charset=utf-8',
                        data: JSON.stringify(payload)
                    }).always(function () {
                        isLoggingSiteError = false;
                    });
                } catch (e) {
                    isLoggingSiteError = false;
                }
            }

            window.logClientSiteError = sendSiteError;

            window.addEventListener('error', function (event) {
                var target = event && event.target;

                if (target && target !== window) {
                    var sourceUrl = target.src || target.href || window.location.pathname;
                    if (shouldSkip(sourceUrl)) return;

                    sendSiteError({
                        Error_Code: 'RESOURCE_ERR',
                        Exception_Message: 'Resource load error',
                        Exception_Stack_Trace: sourceUrl,
                        Source: 'Client Resource',
                        Description: 'Severity: Medium',
                        Web_URL: sourceUrl
                    });
                    return;
                }

                sendSiteError({
                    Error_Code: 'JS_ERR',
                    Exception_Message: event && event.message ? event.message : 'JavaScript error',
                    Exception_Stack_Trace: event && event.error && event.error.stack ? event.error.stack : ((event && event.filename ? event.filename : '') + ' Line: ' + (event && event.lineno ? event.lineno : '0')),
                    Source: 'Client Script',
                    Description: 'Severity: High',
                    Web_URL: window.location.pathname + window.location.search
                });
            }, true);

            window.addEventListener('unhandledrejection', function (event) {
                var reason = event ? event.reason : null;
                var message = 'Unhandled promise rejection';
                var stack = '';

                if (typeof reason === 'string') {
                    message = reason;
                } else if (reason) {
                    message = reason.message || message;
                    stack = reason.stack || '';
                }

                sendSiteError({
                    Error_Code: 'PROMISE_ERR',
                    Exception_Message: message,
                    Exception_Stack_Trace: stack,
                    Source: 'Client Promise',
                    Description: 'Severity: High',
                    Web_URL: window.location.pathname + window.location.search
                });
            });

            $(document).ajaxError(function (event, jqxhr, settings, thrownError) {
                var failedUrl = settings && settings.url ? settings.url : window.location.pathname;
                if (shouldSkip(failedUrl)) return;

                sendSiteError({
                    Error_Code: 'AJAX_ERR',
                    Exception_Message: thrownError || ('AJAX request failed with status ' + (jqxhr ? jqxhr.status : '0')),
                    Exception_Stack_Trace: jqxhr && jqxhr.responseText ? jqxhr.responseText.substring(0, 2000) : '',
                    Source: 'Client AJAX',
                    Description: 'Severity: High | Status: ' + (jqxhr ? jqxhr.status : '0'),
                    Web_URL: failedUrl
                });
            });

            $(document).on('click', 'button, input[type="button"], input[type="submit"], a', function () {
                try {
                    var $element = $(this);
                    var actionName = detectActionName($element);
                    if (!actionName) {
                        var rawText = (($element.text() || $element.val() || '') + '').toLowerCase().trim();
                        if (rawText.indexOf('login') >= 0) actionName = 'Login';
                        else if (rawText.indexOf('verify') >= 0) actionName = 'Verify';
                    }
                    if (!actionName) return;

                    markActionContext(actionName, ($element.text() || $element.val() || '').trim());
                    setTimeout(hookShowErrMsg, 0);
                    setTimeout(hookShowErrorMsg, 0);
                    setTimeout(captureMessageFromDom, 1200);
                } catch (e) { }
            });

            $(document).on('submit', 'form', function () {
                try {
                    markActionContext('Save', (this && this.id) ? this.id : 'form-submit');
                    setTimeout(hookShowErrMsg, 0);
                    setTimeout(hookShowErrorMsg, 0);
                    setTimeout(captureMessageFromDom, 1200);
                } catch (e) { }
            });

            hookShowErrMsg();
            hookShowErrorMsg();
            setInterval(hookShowErrMsg, 1500);
            setInterval(hookShowErrorMsg, 1500);

            if (window.MutationObserver && document.body) {
                try {
                    var observer = new MutationObserver(function () {
                        captureMessageFromDom();
                    });
                    observer.observe(document.body, { childList: true, subtree: true, characterData: true, attributes: true, attributeFilter: ['style', 'class'] });
                } catch (e) { }
            }

            if (window.fetch) {
                var originalFetch = window.fetch;
                window.fetch = function () {
                    var fetchArgs = arguments;
                    var requestUrl = fetchArgs && fetchArgs[0];

                    return originalFetch.apply(window, fetchArgs).then(function (response) {
                        var resolvedUrl = '';
                        try {
                            resolvedUrl = response && response.url ? response.url : (typeof requestUrl === 'string' ? requestUrl : (requestUrl && requestUrl.url ? requestUrl.url : window.location.pathname));
                        } catch (e) {
                            resolvedUrl = window.location.pathname;
                        }

                        if (response && !response.ok && !shouldSkip(resolvedUrl)) {
                            sendSiteError({
                                Error_Code: 'FETCH_ERR',
                                Exception_Message: 'Fetch request failed with status ' + response.status,
                                Exception_Stack_Trace: response.statusText || '',
                                Source: 'Client Fetch',
                                Description: 'Severity: High | Status: ' + response.status,
                                Web_URL: resolvedUrl
                            });
                        }

                        return response;
                    }).catch(function (error) {
                        var failedUrl = typeof requestUrl === 'string' ? requestUrl : (requestUrl && requestUrl.url ? requestUrl.url : window.location.pathname);
                        if (!shouldSkip(failedUrl)) {
                            sendSiteError({
                                Error_Code: 'FETCH_ERR',
                                Exception_Message: error && error.message ? error.message : 'Fetch request exception',
                                Exception_Stack_Trace: error && error.stack ? error.stack : '',
                                Source: 'Client Fetch',
                                Description: 'Severity: High',
                                Web_URL: failedUrl
                            });
                        }

                        throw error;
                    });
                };
            }
        })();
    </script>

    <script>
        $(function () {
            if (window.AutoScaleLayout && typeof window.AutoScaleLayout.initialize === 'function') {
                window.AutoScaleLayout.initialize();
            }

            if (window.FormNavigationUtility && typeof window.FormNavigationUtility.initialize === 'function') {
                window.FormNavigationUtility.initialize();
            }
        });
    </script>


