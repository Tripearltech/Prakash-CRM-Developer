
@{
    ViewBag.Title = "FeedBackQuestion";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Feedback Question</li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div class="card">
        <div class="card-body">
            <div class="text-start mb-3">
                <button id="btnNewFeedbackQuestion" type="button" class="btn btn-primary"><i class="bx bx-plus"></i> New</button>
            </div>
            <div class="">
                <div class="row">
                    <div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <table class="table mb-0 table-striped">
                                    <thead>
                                        <tr>

                                            <th scope="col">Action</th>
                                            <th scope="col">Feedback Question No.</th>
                                            <th scope="col">Order No</th>
                                            <th scope="col">Feedback Question</th>
                                            <th scope="col">Is Active</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblFeedBackQuestionList">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="feedbackQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Feedback Question</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Feedback Question</label>
                    <input type="text" id="txtFeedbackQuestion" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Order No</label>
                    <input type="text" id="txtOrderNo" class="form-control" />
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="chkIsActive" checked>
                    <label class="form-check-label" for="chkIsActive">Is Active</label>
                </div>
                <input type="hidden" id="hdnFeedbackQuestionNo" />
            </div>
            <div class="modal-footer">
                <button id="btnSaveFeedbackQuestion" type="button" class="btn btn-success">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/appjs/FeedBackQuestion.js"></script>
