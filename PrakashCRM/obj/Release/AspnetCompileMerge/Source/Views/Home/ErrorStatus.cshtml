@{
    Layout = null;
    var errorCode = ViewBag.ErrorCode ?? 500;
    var errorTitle = ViewBag.ErrorTitle ?? "Server Error";
    var errorMessage = ViewBag.ErrorMessage ?? "An unexpected error occurred while processing your request.";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error @errorCode</title>
    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: #f4f7fb;
            color: #1f2937;
        }

        .page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            width: 100%;
            max-width: 520px;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
            padding: 32px;
        }

        .code {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            background: #e8eefc;
            color: #1d4ed8;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.04em;
        }

        h1 {
            margin: 16px 0 8px;
            font-size: 30px;
            line-height: 1.2;
        }

        p {
            margin: 0;
            font-size: 15px;
            line-height: 1.7;
            color: #4b5563;
        }

        .actions {
            margin-top: 24px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        a {
            text-decoration: none;
            border-radius: 10px;
            padding: 12px 16px;
            font-weight: 600;
        }

        .primary {
            background: #1d4ed8;
            color: #ffffff;
        }

        .secondary {
            background: #eef2f7;
            color: #111827;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="card">
            <span class="code">Error @errorCode</span>
            <h1>@errorTitle</h1>
            <p>@errorMessage</p>
            <div class="actions">
                <a class="primary" href="/Account/Login">Go to Login</a>
                <a class="secondary" href="javascript:window.location.reload();">Reload</a>
            </div>
        </div>
    </div>
</body>
</html>