@{
    ViewBag.Title = "StockManagement";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Stock Management
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />

    <div class="card">
        <div class="card-body">
            <div class="">
                <div class="row">
                    <div>
                        <div class="row g-3">
                            <div class="col-md-7">
                                <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <table class="table mb-0 table-striped">
                                    <thead>
                                        <tr>
                                            <th scope="col">Branch Name</th>
                                            <th scope="col">OpenStock</th>
                                            <th scope="col">Inward</th>
                                            <th scope="col">Outward</th>
                                            <th scope="col">Closing</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblStockManagement">
                                    </tbody>
                                   
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="DetailsModal" tableindex="-1" aria-labelledby="DetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Stock Management</h5>
            </div>
            <div class="modal-body" style="max-height:450px; overflow-y:auto;">
                <table class="table mb-0 table-striped">
                    <thead class="sticky-top bg-white" style="top: -20px;">
                        <tr>
                            <th scope="col"></th>
                            <th scope="col">Product Name</th>
                            <th scope="col">WareHouse</th>
                            <th scope="col">Today's OpeningStock</th>
                            <th scope="col">Inward</th>
                            <th scope="col">Outward</th>
                            <th scope="col">ClosingStock</th>
                            <th scope="col">UOM</th>
                            <th scope="col">MRP</th>
                            <th scope="col">Expected Shipment</th>
                            <th scope="col">Expected reciept</th>
                        </tr>
                    </thead>
                    <tbody id="tbleStockProductManagement">
                    </tbody>
                    <tfoot id="ftableBody">
                    </tfoot>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div> 
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/reportjs/StockManagement.js"></script>
