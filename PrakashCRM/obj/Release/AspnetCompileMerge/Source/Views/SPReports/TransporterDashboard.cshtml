
@{
    ViewBag.Title = "TransporterDashboard";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}
<link href="~/Content/appcss/paginationFilterCss.css" rel="stylesheet" />
<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Transporter Dashboard
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div class="card">
        <div class="card-body">
            <div class="row">

                <div class="row g-3">
                    <div class="col-md-2">
                        <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                    </div>
                    <div class="col-md-12">
                        <table id="dataList" class="table mb-0 table-striped">
                            <thead>
                                <tr>
                                    <th scope="col">Inv Date</th>
                                    <th scope="col">Inv No</th>
                                    <th scope="col">Product</th>
                                    <th scope="col">Qty</th>
                                    <th scope="col">Pick Up Location</th>
                                    <th scope="col">Destination Location </th>
                                    <th scope="col">Transpoter Name</th>
                                    <th scope="col">Vehicle No</th>
                                    <th scope="col">LR NO</th>
                                    <th scope="col">Freight</th>
                                    <th scope="col">Load/unload</th>
                                    <th scope="col">Remarks</th>
                                </tr>
                            </thead>
                            <tbody id="tblTransporterdashboard">
                            </tbody>
                        </table>
                        <input id="hdnSPSICount" style="display:none" />
                        <input id="hdnLoggedInUserSPCode" value="@Session["loggedInUserSPCode"]" style="display:none" />
                    </div>
                </div>

            </div>
            <div class="row">
                <div>
                    <div class="row g-3">

                        <div class="col-md-12">
                            <div class="row row-cols-auto g-3">
                                <div class="col">
                                    <label class="col-form-label" style="font-weight:bold">Per Page Records: </label>
                                </div>
                                <div class="col">
                                    <select id="ddlRecPerPage" class="form-select">
                                        <option value="10">10</option>
                                        <option value="20">20</option>
                                        <option value="30">30</option>
                                    </select>
                                </div>
                                <div class="col">
                                    <ul class="pagination pagination-lg pager" id="myPager"></ul>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/reportjs/Transporterdashboard.js"></script>
