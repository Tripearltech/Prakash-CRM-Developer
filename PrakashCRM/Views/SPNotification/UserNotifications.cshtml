@{
    ViewBag.Title = "UserNotifications";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-home-alt"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">All Notifications</li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />

    <div class="card border-0" style="background:linear-gradient(135deg,#fff7e8 0%,#ffffff 60%,#eef7ff 100%)">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h4 class="mb-1">Notification Center</h4>
                    <p class="text-muted mb-0">Recent activity updates for inquiries, quotes, orders, and invoices.</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-dark" id="notificationPageUnreadBadge">0 unread</span>
                    <button id="notificationPageMarkAllRead" type="button" class="btn btn-outline-dark btn-sm">Mark all as read</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 mb-3" id="notificationPageFilters">
                <button type="button" class="btn btn-sm btn-outline-dark notification-filter-chip active" data-filter="All">All</button>
                <button type="button" class="btn btn-sm btn-outline-dark notification-filter-chip" data-filter="Inquiry">Inquiry</button>
                <button type="button" class="btn btn-sm btn-outline-dark notification-filter-chip" data-filter="Quote">Quote</button>
                <button type="button" class="btn btn-sm btn-outline-dark notification-filter-chip" data-filter="Order">Order</button>
                <button type="button" class="btn btn-sm btn-outline-dark notification-filter-chip" data-filter="Invoice">Invoice</button>
                <button type="button" class="btn btn-sm btn-outline-dark notification-filter-chip" data-filter="Item">Item</button>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                <div id="notificationPageSummary" class="text-muted small">Loading notifications...</div>
                <div class="d-flex align-items-center gap-2">
                    <label for="notificationPageSize" class="small text-muted mb-0">Per page</label>
                    <select id="notificationPageSize" class="form-select form-select-sm" style="width:auto">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                    </select>
                </div>
            </div>

            <div id="allNotificationsList">
                <div class="notification-page-empty">Loading notifications...</div>
            </div>

            <div id="notificationPagePager" class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-3" style="display:none">
                <button id="notificationPagePrev" type="button" class="btn btn-outline-dark btn-sm">Previous</button>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <div id="notificationPageNumbers" class="btn-group btn-group-sm flex-wrap" role="group" aria-label="Notification pagination"></div>
                    <div id="notificationPageInfo" class="small text-muted"></div>
                </div>
                <button id="notificationPageNext" type="button" class="btn btn-outline-dark btn-sm">Next</button>
            </div>
        </div>
    </div>
</div>
