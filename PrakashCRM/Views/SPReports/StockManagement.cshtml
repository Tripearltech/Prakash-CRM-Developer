<div class="modal fade" id="DetailsModal" tabindex="-1" aria-labelledby="DetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Stock Management</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            
            <div class="px-3 pt-2 pb-2">
                <div class="d-flex align-items-center gap-2">

                    <label class="mb-0 fw-bold">Product</label>

                    <select id="ddlProductSearch" class="form-select" style="width: 280px;"></select>
                    @*<input type="text" id="txtProductSearch" class="form-control" placeholder="Search Product..." />*@
                    <button id="btnSearchProduct" class="btn btn-primary">
                        <i class="bx bx-search"></i> Search
                    </button>

                    <button id="btnClearProduct" class="btn btn-secondary">
                        <i class="bx bx-refresh"></i> Refresh
                    </button>

                </div>
            </div>
 
            <div class="modal-body pt-0" style="max-height:450px; overflow-y:auto;">
                <table class="table table-striped mb-0">
                    <thead class="sticky-top bg-white">
                        <tr>
                            <th></th>
                            <th>Product Name</th>
                            <th>WareHouse</th>
                            <th>Today's OpeningStock</th>
                            <th>Inward</th>
                            <th>Outward</th>
                            <th>ClosingStock</th>
                            <th>UOM</th>
                            <th>MRP</th>
                            <th>Expected Shipment</th>
                            <th>Expected receipt</th>
                        </tr>
                    </thead>
                    <tbody id="tbleStockProductManagement"></tbody>
                    <tfoot id="ftableBody"></tfoot>
                </table>
            </div>

            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/reportjs/StockManagement.js"></script>
