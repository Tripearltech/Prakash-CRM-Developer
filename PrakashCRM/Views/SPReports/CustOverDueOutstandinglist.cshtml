
@{
    ViewBag.Title = "CustOverDueOutstandinglist";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<link href="~/Content/appcss/paginationFilterCss.css" rel="stylesheet" />

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="#"> Reports </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        CustOver Due list
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
        <div class="card">
            <div class="card-body position-relative">
                <div id="custOverdueLoader" class="customer-outstanding-loader d-none" aria-hidden="true">
                    <div class="customer-outstanding-loader-content app-loader-card text-center">
                        <span class="app-loader-spinner customer-outstanding-loader-spinner" role="status" aria-label="Loading"></span>
                        <p class="app-loader-text mb-0 mt-2">Loading customer data...</p>
                    </div>
                </div>

                <input id="hdnLoggedInSPCode" type="hidden" value="@Convert.ToString(Session["loggedInUserSPCode"])" />
                <input id="hdnLoggedInUserNo" type="hidden" value="@Convert.ToString(Session["loggedInUserNo"])" />
                
                @{
                    string debugSPCode = Convert.ToString(Session["loggedInUserSPCode"]);
                    string debugUserNo = Convert.ToString(Session["loggedInUserNo"]);
                }
            <div class="row g-2 align-items-center mb-3">

                <!-- As on Date -->
                <div class="col-md-4">
                    <div class="d-flex align-items-center">
                        <label for="txtAsOnDate" class="fw-bold me-2 mb-0" style="min-width:120px;">Current Date:</label>
                        <input id="txtAsOnDate" type="date" class="form-control" />
                    </div>
                </div>

                <!-- Customer -->
                <div class="col-md-4 position-relative">
                    <div class="d-flex align-items-center">
                        <label for="txtCustomerSearch" class="fw-bold me-2 mb-0" style="min-width:120px;">Customer:</label>
                        <input id="txtCustomerSearch" type="text" class="form-control" />
                    </div>

                    <!-- Dropdown -->
                    <ul id="dlCustomerSearch"
                        class="list-unstyled border bg-white shadow-sm rounded position-absolute w-100 mb-0"
                        style="display:none;max-height:220px;overflow-y:auto;z-index:1055;top:100%;left:0;">
                    </ul>
                </div>

                <!-- Search Button -->
                <div class="col-md-auto">
                    <button id="btnCustomerSearch" type="button" class="btn btn-primary">
                        Search
                    </button>
                </div>

                <div class="col-md-auto">
                    <button id="btnCustomerRefresh" type="button" class="btn btn-success">
                        Refresh
                    </button>
                </div>

                <!-- Export Dropdown -->
                <div class="col-md-auto">
                    <div class="d-flex align-items-center">
                        <label class="fw-bold me-2 mb-0">Export</label>
                        <select id="ddlCustomerExportType" class="form-select">
                            <option value="">--Select--</option>
                            <option value="Excel">Excel</option>
                            <option value="PDF">PDF</option>
                        </select>
                    </div>
                </div>

                <!-- Export Button -->
                <div class="col-md-auto">
                    <button id="btnCustomerExport" type="button" class="btn btn-primary">
                        Export
                    </button>
                </div>

            </div>

                <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
                    <table id="tblCustomerSummaryList" class="table table-striped table-hover table-bordered mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="sticky-top bg-light" style="z-index:2;">Customer Name</th>
                                <th scope="col" class="text-end sticky-top bg-light" style="z-index:2;">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="tblCustomerSummary"></tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td class="text-start">Total</td>
                                <td id="lblRemainAmountTotal" class="text-end">0.00</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
</div>

@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/reportjs/CustOverDueOutstanding.js"></script>
