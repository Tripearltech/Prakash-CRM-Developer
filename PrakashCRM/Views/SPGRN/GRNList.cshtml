@model IEnumerable<PrakashCRM.Data.Models.SPGRNList>
@{
    ViewBag.Title = "GRNList";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<style>
    .Incoming, .Incoming a {
        color: orange !important;
        font-weight: 500;
    }

    .MapVendor, .MapVendor a {
        color: red !important;
        font-weight: 500;
    }
    /* 🔥 scroll container */
    .table-scroll {
        overflow-y: auto;
    }

    .grn-list-page .grn-filter-toolbar {
        justify-content: flex-end;
        align-items: center;
        row-gap: 12px;
    }

    .grn-list-page .grn-filter-toolbar .form-select,
    .grn-list-page .grn-filter-toolbar .form-control,
    .grn-list-page .grn-filter-toolbar .btn {
        min-height: 38px;
    }

    .grn-list-page .grn-filter-toolbar #ddlField,
    .grn-list-page .grn-filter-toolbar #ddlOperator,
    .grn-list-page .grn-filter-toolbar #dvtxtSearch {
        min-width: 180px;
    }

        /* 🔥 sticky header (FORCE FIX) */
        .table-scroll thead th {
            position: sticky !important;
            top: 0;
            background: #f8f9fa;
            z-index: 10;
        }

    /* 🔥 important for bootstrap conflict */
    .table {
        border-collapse: separate;
        border-spacing: 0;
    }

    @@media (max-width: 991.98px) {
        .grn-list-page .grn-filter-toolbar {
            justify-content: flex-start;
        }

        .grn-list-page .grn-filter-toolbar #ddlField,
        .grn-list-page .grn-filter-toolbar #ddlOperator,
        .grn-list-page .grn-filter-toolbar #dvtxtSearch {
            min-width: 100%;
            width: 100%;
        }
    }
</style>
<link href="~/Content/appcss/paginationFilterCss.css" rel="stylesheet" />
<div class="page-content grn-list-page">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">GRN List</li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div>
                    <div class="row g-3">
                        <div class="col-md-2">
                            <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                            <input id="getLoggedInUserNo" value="@Session["loggedInUserNo"].ToString()" style="display:none" />
                            @*<button id="btnAcceptSelected" class="btn btn-primary  mb-3 mb-lg-0" type="button" onclick="AccceptTask();"><i class='bx bx-message-square-check'></i>&nbsp;Accept</button>*@
                        </div>

                        <div class="col-md-10">
                            <div class="row row-cols-auto g-3 grn-filter-toolbar">
                                <div class="col">
                                    <label class="col-form-label">Filter:</label>
                                </div>
                                <div class="col">
                                    <select id="ddlField" class="form-select">
                                        <option value="-1">---Select---</option>
                                        <option value="No_Filter_FilterOnly">Order No</option>
                                        <option value="OrderDate_Filter_FilterOnly">Order Date</option>
                                        <option value="Name_Filter_FilterOnly">Name</option>
                                        <option value="ProductName_Filter_FilterOnly">Product Name</option>
                                    </select>
                                </div>
                                <div class="col">
                                    <input id="txtFromDate" type="date" class="form-control" style="display:none">
                                    <select id="ddlOperator" class="form-select">
                                        <option value="-1">---Select---</option>
                                        <option value="Equal">Equal</option>
                                        <option value="Not Equal">Not Equal</option>
                                        <option value="Starts With">Starts With</option>
                                        <option value="Ends With">Ends With</option>
                                        <option value="Contains" selected>Contains</option>
                                        @*<option value="Less Than">Less Than</option>
                                            <option value="Greater Than">Greater Than</option>*@
                                    </select>
                                </div>
                                <div class="col">
                                    <input id="txtToDate" type="date" class="form-control" style="display:none">
                                    <div id="dvtxtSearch" class="position-relative">
                                        <input id="txtSearch" type="text" class="form-control ps-5" placeholder="Search Product..."> <span class="position-absolute top-50 product-show translate-middle-y"><i class="bx bx-search"></i></span>
                                    </div>
                                </div>
                                <div class="col">
                                    <button id="btnSearch" class="btn btn-primary" type="button"><i class="bx bx-search"></i>Search</button>
                                    &nbsp;
                                    <button id="btnClearFilter" class="btn btn-primary" type="button">
                                        <i class="bx bx-rotate-right me-0"></i>&nbsp;Refresh
                                    </button>
                                </div>
                                <div style="display:none" class="col">
                                    <button id="btnExport" class="btn btn-primary" type="button"><i class="bx bxs-file"></i>Export</button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-12">
            <div class="table-responsive table-scroll" data-auto-scale-height="table" data-auto-scale-offset="32">
                <table id="dataList" class="display responsive nowrap" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th></th>
                            <th>Order No</th>
                            <th>Order Date</th>
                            <th>Name</th>
                            <th>Document Type</th>
                            <th>Product Name</th>
                            <th>Outstanding Qty.</th>
                            <th>Packing Style</th>
                            <th>Purchaser Name</th>
                            <th>Contact Name</th>
                            <th>Contact PhoneNo</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/appjs/SPGRNList.js"></script>
