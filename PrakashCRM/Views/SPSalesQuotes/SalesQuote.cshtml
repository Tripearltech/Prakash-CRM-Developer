    function parseAmount(value) {
        if (value === null || value === undefined) return 0;
        var s = value.toString().replace(/,/g, '').trim();
        if (s === '') return 0;
        var n = parseFloat(s);
        return isNaN(n) ? 0 : n;
    }

    function parseBool(value) {
        if (value === true || value === false) return value;
        var s = (value || "").toString().trim().toLowerCase();
        return (s === "true" || s === "yes" || s === "1");
    }

    function setSQJustificationFieldValidity(selector, isValid) {
        $(selector).toggleClass('is-invalid', !isValid);
    }

    function resetSQJustificationValidation() {
        setSQJustificationFieldValidity('#txtJustification1', true);
        setSQJustificationFieldValidity('#txtTargetDate', true);
        setSQJustificationFieldValidity('#txtJustification2', true);
        $('#lblSQJustificationValidation').hide().text('');
    }

    function getSQJustificationValidationState() {
        var invalidFields = [];
        var justification1Visible = $('#Justification1').is(':visible');
        var targetDateVisible = $('#targetDate').is(':visible');
        var justification2Visible = $('#Justification2').is(':visible');

        var justification1Value = ($('#txtJustification1').val() || '').toString().trim();
        var targetDateValue = ($('#txtTargetDate').val() || '').toString().trim();
        var justification2Value = ($('#txtJustification2').val() || '').toString().trim();

        var justification1Valid = !justification1Visible || justification1Value !== '';
        var targetDateValid = !targetDateVisible || targetDateValue !== '';
        var justification2Valid = !justification2Visible || justification2Value !== '';

        setSQJustificationFieldValidity('#txtJustification1', justification1Valid);
        setSQJustificationFieldValidity('#txtTargetDate', targetDateValid);
        setSQJustificationFieldValidity('#txtJustification2', justification2Valid);

        if (!justification1Valid) {
            invalidFields.push('Negative Credit Limit Justification');
        }

        if (!targetDateValid) {
            invalidFields.push('Target Date');
        }

        if (!justification2Valid) {
            invalidFields.push('Negative Margin Justification');
        }

        return {
            isValid: invalidFields.length === 0,
            message: invalidFields.length > 0 ? 'Enter ' + invalidFields.join(', ') + ' to continue.' : ''
        };
    }

    function updateSQJustificationSubmitState(showMessage) {
        var validationState = getSQJustificationValidationState();
        $('#btnConfirmSaveSQ').prop('disabled', !validationState.isValid);

        if (showMessage && !validationState.isValid) {
            $('#lblSQJustificationValidation').show().text(validationState.message);
        } else {
            $('#lblSQJustificationValidation').hide().text('');
        }

        return validationState.isValid;
    }

    function SaveSalesQuote() {
        if ($('#modalJustification').is(':visible') && !updateSQJustificationSubmitState(true)) {
            return;
        }

        $('#divImage').show();
        $('#btnConfirmSaveSQSpinner').show();

        var salesquoteheader = {};
        var productDetails_ = [];

        // Header Info
        salesquoteheader.IsSQEdit = $('#hfSQEdit').val();
        salesquoteheader.QuoteNo = $('#hfSalesQuoteNo').val();
        salesquoteheader.NoSeriesCode = $('#hfNoSeriesCode').val();
        salesquoteheader.InquiryNo = $('#txtInqNo').val();
        var location = $('#ddlLocations').val();
        var Loc = location.split("_");
        var loc = Loc[0];
        salesquoteheader.LocationCode = loc;
        salesquoteheader.OrderDate = $('#txtSalesQuoteDate').val();
        salesquoteheader.ContactCompanyNo = $('#hfContactCompanyNo').val();
        salesquoteheader.ContactCompanyName = $('#txtCustomerName').val();
        salesquoteheader.ContactPersonNo = $('#ddlContactName').val();
        salesquoteheader.ContactPersonName = $('#ddlContactName option:selected').text();
        salesquoteheader.CustomerNo = $('#hfCustomerNo').val();
        salesquoteheader.TotalCreditLimit = $('#txtTotalCreditLimit').val();
        salesquoteheader.UsedCreditLimit = $('#hfUsedCreditLimit').val();
        salesquoteheader.AvailableCreditLimit = $('#txtAvailableCreditLimit').val();
        salesquoteheader.OutstandingDue = $('#txtOutstandingDue').val();
        salesquoteheader.PaymentMethodCode = $('#ddlPaymentMethods').val();
        salesquoteheader.TransportMethodCode = $('#ddlTransportMethod').val();

            const paymentTermsValue = ($('#ddlPaymentTerms').val() || '').toString();
            const PaymentTermsDetails = paymentTermsValue && paymentTermsValue !== '-1' ? paymentTermsValue.split('_') : [];
            salesquoteheader.PaymentTermsCode = PaymentTermsDetails.length > 0 ? PaymentTermsDetails[0] : '';
        salesquoteheader.ShipmentMethodCode = $('#ddlIncoTerms').val();
        salesquoteheader.ConsigneeAddress = $('#ddlConsigneeAddress').val();
        salesquoteheader.ShiptoCode = $('#ddlBillTo').val();
        salesquoteheader.JobtoCode = $('#ddlDeliveryTo').val();
        salesquoteheader.JobtoAddress = $('#ddlDeliveryTo option:selected').text();
        salesquoteheader.CustomerTemplateCode = $('#hfCustomerTemplateCode').val();
        salesquoteheader.JustificationFor = $('#JustificationTitle').text();
        // Only one of these is used depending on the scenario; avoid overwriting with blank.
        salesquoteheader.JustificationDetails = ($('#txtJustification1').val() || '').toString().trim();
        if (!salesquoteheader.JustificationDetails) {
            salesquoteheader.JustificationDetails = ($('#txtJustification2').val() || '').toString().trim();
        }
        salesquoteheader.ApprovalFor = $('#hfApprovalFor').val();
        salesquoteheader.TargetDate = $('#txtTargetDate').val();
        salesquoteheader.ValidUntillDate = $('#txtSQValidUntillDate').val();
        salesquoteheader.PCPL_Packing_MRP_Price = $('#txtMRPPrice').val();

        // Product Details
        $("#tblProducts TR[id^='ProdTR_']").each(function () {
            var productDetails = {};
            var isLiquidProd = parseBool(typeof sqGetRowCellText === 'function' ? sqGetRowCellText($(this), 31) : $(this).find("TD").eq(31).text());

            var prodNo = ($(this).find("TD").eq(2).text() || "").toString().trim();
            productDetails.No = prodNo;
            productDetails.ProductName = $(this).find("TD").eq(3).text();
            productDetails.Quantity = parseFloat($(this).find("TD").eq(4).html()) || 0;
            productDetails.Unit_Price = parseFloat($(this).find("TD").eq(8).html()) || 0;

            // Use Packing Style CODE (value) instead of text
            productDetails.PCPL_Packing_Style_Code = $(this).find("TD").eq(6).attr("data-code") || $(this).find("TD").eq(6).html();

            productDetails.PCPL_Purchase_Cost = parseAmount($(this).find("TD").eq(7).text());
            productDetails.PCPL_MRP = parseAmount($(this).find("TD").eq(36).text());
            productDetails.Delivery_Date = $(this).find("TD").eq(12).html();
            productDetails.PCPL_Total_Cost = $(this).find("TD").eq(13).html();
            productDetails.PCPL_Margin = $(this).find("TD").eq(14).html();
            productDetails.PCPL_Transport_Method = $(this).find("TD").eq(17).html();
            productDetails.PCPL_Transport_Cost = $(this).find("TD").eq(18).html();
            productDetails.PCPL_Sales_Discount = $(this).find("TD").eq(19).html();

            productDetails.PCPL_Commission_Type = $(this).find("TD").eq(20).html() || "";
            productDetails.PCPL_Commission = parseFloat($(this).find("TD").eq(21).html()) || 0;
            productDetails.PCPL_Commission_Amount = parseFloat($(this).find("TD").eq(22).html()) || 0;
            productDetails.PCPL_Credit_Days = parseFloat($(this).find("TD").eq(23).html()) || 0;
            productDetails.PCPL_Interest = parseFloat($(this).find("TD").eq(24).html()) || 0;
            productDetails.PCPL_Commission_Payable = ($(this).find("TD").eq(29).html() === " ") ? "" : $(this).find("TD").eq(29).html();
            productDetails.PCPL_Packing_MRP_Price = ($(this).find("TD").eq(36).html() === " ") ? "" : $(this).find("TD").eq(36).html();

            var _np = (typeof sqGetRowCellText === 'function') ? sqGetRowCellText($(this), 9) : $(this).find("TD").eq(9).text();
            var _nm = (typeof sqGetRowCellText === 'function') ? sqGetRowCellText($(this), 10) : $(this).find("TD").eq(10).text();
            var _pu = (typeof sqGetRowCellText === 'function') ? sqGetRowCellText($(this), 11) : $(this).find("TD").eq(11).text();
            productDetails.New_Price = parseAmount(_np);
            productDetails.New_Margin = parseAmount(_nm);
            productDetails.Price_Updated = parseBool(_pu);

            // Requirement: while saving, always send New Price/New Margin as 0 (default).
            productDetails.New_Price = 0;
            productDetails.New_Margin = 0;
            var dropShipHtml = $("#" + prodNo + "_DropShipment").html();
            if (dropShipHtml === "Yes") {
                productDetails.Drop_Shipment = true;
                productDetails.PCPL_Vendor_No = $(this).find("TD").eq(35).html();
                if (productDetails.PCPL_Vendor_No == " ") productDetails.PCPL_Vendor_No = "";
            } else {
                productDetails.Drop_Shipment = false;
                productDetails.PCPL_Vendor_No = "";
            }


            // Preserve Inquiry Line No (if present)
            var inqProdLineNo = (($("#" + prodNo + "_InqProdLineNo").text() || "").toString().trim());
            if (inqProdLineNo !== "") {
                productDetails.InqProdLineNo = inqProdLineNo;
            }

            // Critical for update: Sales Quote Line_No must be sent.
            // Read from row attribute first (kept in SalesQuote.js), fallback to hidden label.
            var rowLineNo = parseInt((($(this).attr('data-lineno') || "").toString().trim())) || 0;
            if (!rowLineNo || rowLineNo <= 0) {
                rowLineNo = parseInt(((("#" + prodNo + "_SQLineNo") && $("#" + prodNo + "_SQLineNo").text()) || "0").toString().trim()) || 0;
            }

            if ($('#hfSQEdit').val() === "true") {
                productDetails.Line_No = rowLineNo;
            } else {
                // For create-from-inquiry flows, keep existing behavior.
                productDetails.Line_No = parseInt(inqProdLineNo || '0') || 0;
            }

            var marginPercent = $("#" + prodNo + "_MarginPercent").html() || "0%";
            marginPercent = marginPercent.replace('%', '');
            productDetails.PCPL_Margin_Percent = parseFloat(marginPercent) || 0;

            var pendingLineOverride = null;
            try {
                if (typeof sqGetPendingLineSaveOverride === 'function') {
                    pendingLineOverride = sqGetPendingLineSaveOverride(prodNo);
                }
            } catch (e) { }

            if (pendingLineOverride) {
                productDetails.Unit_Price = parseAmount(pendingLineOverride.Unit_Price);
                productDetails.PCPL_Total_Cost = parseAmount(pendingLineOverride.PCPL_Total_Cost);
                productDetails.PCPL_Margin = parseAmount(pendingLineOverride.PCPL_Margin);
                productDetails.PCPL_Margin_Percent = parseAmount(pendingLineOverride.PCPL_Margin_Percent);
                productDetails.PCPL_Commission_Amount = parseAmount(pendingLineOverride.PCPL_Commission_Amount);
                productDetails.Price_Updated = parseBool(pendingLineOverride.Price_Updated);
                productDetails.New_Price = 0;
                productDetails.New_Margin = 0;
            }

            // Liquid Product Details
            productDetails.IsLiquidProd = isLiquidProd;
            if (isLiquidProd) {
                productDetails.PCPL_Concentration_Rate_Percent = parseFloat($(this).find("TD").eq(32).html()) || 0;
                productDetails.Net_Weight = parseFloat($(this).find("TD").eq(33).html()) || 0;
                productDetails.PCPL_Liquid_Rate = parseFloat($(this).find("TD").eq(34).html()) || 0;
            } else {
                productDetails.PCPL_Concentration_Rate_Percent = "";
                productDetails.Net_Weight = 0;
                productDetails.PCPL_Liquid_Rate = "";
            }

            productDetails_.push(productDetails);
        });

        salesquoteheader.Products = productDetails_;

        // AJAX POST
        $.ajax({
            type: "POST",
            url: "/SPSalesQuotes/PostSalesQuote",
            data: JSON.stringify(salesquoteheader),
            contentType: "application/json; charset=utf-8",
            success: function (responseMsg) {
                $('#divImage').hide();
                $('#hfSalesQuoteResDetails').val(responseMsg);

                const responseMsg_ = responseMsg.split(',');
                if ($('#hfSalesQuoteResDetails').val() != "") {
                    var actionMsg = ($('#hfSQEdit').val() === "true")
                        ? responseMsg_[0] + " - Sales Quote Updated Successfully"
                        : responseMsg_[0] + " - Sales Quote Created Successfully";

                    $('#modalJustification').hide();
                    $('#btnConfirmSaveSQSpinner').hide();
                    $('#hfSQEdit').val("false");

                    try {
                        if (typeof initSQPriceColumnIndexes === 'function') initSQPriceColumnIndexes();
                        if (typeof SQ_PENDING_LINE_SAVE_OVERRIDES !== 'undefined') {
                            SQ_PENDING_LINE_SAVE_OVERRIDES = {};
                        }
                        $("#tblProducts TR[id^='ProdTR_']").each(function () {
                            var $tr = $(this);
                            if (typeof sqSetRowCellText === 'function' && typeof SQ_PRICE_COLS !== 'undefined') {
                                sqSetRowCellText($tr, SQ_PRICE_COLS.NEW_PRICE, '0');
                                sqSetRowCellText($tr, SQ_PRICE_COLS.NEW_MARGIN, '0');
                                sqSetRowCellText($tr, SQ_PRICE_COLS.PRICE_UPDATED, 'false');
                            } else {
                                // Fallback to fixed indexes matching the grid header.
                                $tr.find('TD').eq(9).text('0');
                                $tr.find('TD').eq(10).text('0');
                                $tr.find('TD').eq(11).text('false');
                            }
                            if (typeof applySQPriceRowState === 'function') {
                                applySQPriceRowState($tr.attr('id'));
                            }
                        });
                    } catch (e) { }
                    $('#modalSQMsg').show();
                    $('#lblSQMsg').text(actionMsg);
                } else {
                    window.location.reload(false);
                }
            },
            error: function (err) {
                $('#divImage').hide();
                $('#btnConfirmSaveSQSpinner').hide();
                console.error("Error saving Sales Quote:", err);
                alert(err && err.responseText ? err.responseText : "Failed to save Sales Quote. Check console for details.");
            }
        });
    }


    function setTabOrder(isLiquid) {

        let tabIndex = 11;

        
        if (isLiquid) {
            $("#dvLiquidProdFields").show();

            $("#txtNetWeight")
                .prop("disabled", false)
                .attr("tabindex", tabIndex++);

            $("#txtConcentratePercent")
                .prop("disabled", false)
                .attr("tabindex", tabIndex++);

            $("#txtLiquidRate")
                .prop("disabled", false)
                .attr("tabindex", tabIndex++);
        }
        else {
            $("#dvLiquidProdFields").hide();

            $("#txtNetWeight, #txtConcentratePercent, #txtLiquidRate")
                .prop("disabled", true)
                .attr("tabindex", -1);
        }

       
        $("#ddlPackingStyle").attr("tabindex", tabIndex++);
        $("#txtProdQty").attr("tabindex", tabIndex++);

        $("#ddlIncoTerms").attr("tabindex", tabIndex++);
        $("#txtTransportCost").attr("tabindex", tabIndex++);
        $("#txtDeliveryDate").attr("tabindex", tabIndex++);
        $("#txtSalesDiscount").attr("tabindex", tabIndex++);
        $("#txtSalesPrice").attr("tabindex", tabIndex++);
        $("#chkDropShipment").attr("tabindex", tabIndex++);

      
        if ($("#chkDropShipment").is(":checked")) {

            $("#dvVendors").show();

            $("#ddlItemVendors")
                .prop("disabled", false)
                .attr("tabindex", tabIndex++);

        } else {

            $("#dvVendors").hide();

            $("#ddlItemVendors")
                .prop("disabled", true)
                .attr("tabindex", -1);
        }
      
        $("#chkIsCommission").attr("tabindex", tabIndex++);

        if ($("#chkIsCommission").is(":checked")) {

            $("#ddlCommissionPerUnitPercent, #txtCommissionPercent, #txtCommissionAmt")
                .prop("disabled", false);

            $("#ddlCommissionPerUnitPercent").attr("tabindex", tabIndex++);
            $("#txtCommissionPercent").attr("tabindex", tabIndex++);
            $("#txtCommissionAmt").attr("tabindex", tabIndex++);
            $("#ddlCommissionPayable").attr("tabindex", tabIndex++);

        } else {

            $("#ddlCommissionPerUnitPercent, #txtCommissionPercent, #txtCommissionAmt, #ddlCommissionPayable")
                .prop("disabled", true)
                .attr("tabindex", -1);
        }

        $("#btnSaveProd").attr("tabindex", tabIndex++);
    }



    function RedirectToSQApproval() {
        window.location.replace('@salesQuoteBackUrl');
    }

</script>
