﻿
@{
    ViewBag.Title = "SalesQuote";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
    var isApprovalNavigation = string.Equals(Request["ReturnTo"], "SalesQuoteStatus", System.StringComparison.OrdinalIgnoreCase)
        || string.Equals(Request["SQFor"], "ApproveReject", System.StringComparison.OrdinalIgnoreCase);
    var salesQuoteBackUrl = isApprovalNavigation
        ? Url.Action("SalesQuoteStatus", "SPSalesQuotes")
        : Url.Action("SalesQuoteList", "SPSalesQuotes");
    var salesQuoteBackLabel = isApprovalNavigation ? "Sales Quote Status" : "Sales Quote List";
}
<style>
    .InqProdCls, .EditCls,
    .CostSheetCls, .SQLineCls {
        cursor: pointer;
    }

    .sq-price-pending {
        color: red !important;
    }

    .sq-price-updated {
        color: green !important;
    }

    .SQverticalScroll {
        padding: 15px;
        overflow-y: auto;
        min-height: 220px;
        max-height: min(440px, calc(var(--app-viewport-height, 100vh) - 220px));
    }
</style>
<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
