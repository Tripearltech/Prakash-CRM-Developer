@{
    ViewBag.Title = "DispatchDetails";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}
<style>
    /* 🔥 scroll container */
    .table-scroll {
        max-height: 650px;
        overflow-y: auto;
    }

        /* 🔥 sticky header (FORCE FIX) */
        .table-scroll thead th {
            position: sticky !important;
            top: 0;
            background: #f8f9fa;
            z-index: 10;
        }

    /* 🔥 important for bootstrap conflict */
    .table {
        border-collapse: separate;
        border-spacing: 0;
    }
</style>
<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="/SPSalesQuotes/DispatchDetails"> SalesQuotes</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Dispatch Details
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />

    <div class="card">
        <div class="card-body">
            <div class="row">
                <div>
                    <div class="row g-3">
                        <div class="col-md-2">
                            <input type="date" id="FromDate" class="form-control" placeholder="From Date" />
                            <p id="Fdatevalidate" style="color:red"></p>
                        </div>
                        <div class="col-md-2">
                            <input type="date" id="ToDate" class="form-control" placeholder="To Date" />
                            <p id="Tdatevalidate" style="color:red"></p>
                        </div>
                        <div class="col-md-2">
                            <input type="text" class="form-control" id="TxtSearch" placeholder="Document no" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" id="SearchBtn" class="btn btn-primary">Search</button>
                            <button id="btnClearFilter" class="btn btn-primary" type="button">
                                <i class="bx bx-rotate-right "></i>Refresh
                            </button>
                        </div>
                    </div>
                </div>

            </div>
            <div class="table-responsive">
                <div class="row">
                    <div>
                        <div class="row g-3">
                            <div class="col-md-7">
                                <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div>
                        <div class="row g-3">
                            <div class="row mt-3">
                                <div class="col-md-12">

                                    <div class="table-responsive table-scroll">
                                        <table class="table table-striped mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Invoice No</th>
                                                    <th>Date</th>
                                                    <th>Customer No</th>
                                                    <th>Customer Name</th>
                                                    <th>Vehicle No</th>
                                                    <th>LRNo</th>
                                                    <th>SalesQuoteNo</th>
                                                    <th>OrderDetails</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblDispatchDetails"></tbody>
                                        </table>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="DetailsModal" tableindex="-1" aria-labelledby="DetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Order Details</h5>
            </div>
            <div class="modal-body" style="max-height:450px; overflow-y:auto;">
                <table class="table mb-0 table-striped">
                    <thead class="sticky-top bg-white" style="top: -20px;">
                        <tr>
                            <th scope="col">Itemno</th>
                            <th scope="col">Invoice Qty</th>
                            <th scope="col">Total Qty</th>
                            <th scope="col">Price</th>
                        </tr>
                    </thead>
                    <tbody id="tbleOrderDetails"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
@Scripts.Render("~/bundles/jquery")
<script src="~/Scripts/appjs/SalesQtDispatchDetails.js"></script>
