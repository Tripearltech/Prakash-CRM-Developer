@{
    ViewBag.Title = "BusinessPlan";
    Layout = "~/Views/Shared/_SalespersonMasterLayout.cshtml";
}

<div class="page-content">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="/SPDashboard/Index"><i class="bx bx-tachometer"></i>&nbsp;Dashboard</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="/SPBusinessPlan/BusinessPlanContactList">Business Plan Contacts</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Create Business Plan
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <hr />
    <div class="card">
        <div class="card-body" style="padding-bottom:0px">

            <div class="row">
                <div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <h5 style="color: #8833ff">Business Plan For Year Of : <label id="lblFinancialYear"></label></h5>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end">
                        <div>
                            <label style="font-weight: 490;">Item Filter:</label>
                        </div>
                        <div class="row g-2 align-items-center">
                            <div class="col-auto">
                                <input type="text" id="txtitemName" class="form-control" placeholder="Type Item Name" style="width: 300px;" value="" />
                            </div>
                            <input type="hidden" id="hfitemNo" name="" value="" />
                            <div class="col-auto">
                                <button type="button" id="btnSearch" class="btn btn-primary">Search</button>
                            </div>
                            <div class="col-auto">
                                <button type="button" id="btnRefresh" class="btn btn-primary">Refresh</button>
                            </div>
                            <div class="col-auto" style="display:none;">
                                <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"]" />
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="row mb-3">
                                <div class="col-sm-9">
                                    <table>
                                        <tr>
                                            <td><label class="col-form-label" style="font-weight:bold">Customer</label></td>
                                            <td>&nbsp;</td>
                                            <td><label id="lblCustomer"></label></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-sm-3">
                                    <input id="hfBusinessPlanRes" style="display:none" />
                                    <input id="hfContactNo" style="display:none" />
                                    <input id="hfCustomerNo" value="" style="display:none" />

                                    @*<select id="ddlCustomer" class="form-select">
                                        </select>*@
                                    @*@Html.DropDownListFor(model => model.Visit_Type, Enumerable.Empty<SelectListItem>(), new { Value = Model.Visit_Type, @id = "ddlType", @class = "form-select" })*@
                                </div>
                            </div>
                            <div class="col-md-6">
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <div class="row mb-3">
                                    <div class="col-sm-12">
                                        <table class="table mb-0 table-striped">
                                            <thead>
                                                <tr>
                                                    <th hidden></th>
                                                    <th id="ddlProductitem">Product Name</th>
                                                    <th colspan="4" scope="col" align="center" style="font-weight:bold">Prev. Financial Year (<label id="lblPrevFinancialYear"></label>)</th>
                                                    <th colspan="4" scope="col" align="center" style="font-weight:bold">Financial Year (<label id="lblFinancialYearGrid"></label>)</th>
                                                </tr>
                                                <tr>
                                                    <th hidden></th>
                                                    <th></th>
                                                    <th scope="col">Demand<br />Qty</th>
                                                    <th scope="col">Target<br />Qty</th>
                                                    <th scope="col">Achieved<br />Qty</th>
                                                    <th scope="col">Last Year<br />Sale(&#8377;)</th>
                                                    <th scope="col">Demand<br />Qty</th>
                                                    <th scope="col">Target<br />Qty</th>
                                                    <th scope="col">Avg Price</th>
                                                    <th scope="col">Target<br />Revenue</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblCustBusinessPlan">
                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <input id="hdnLoggedInUserSPCode" value="@Session["loggedInUserSPCode"].ToString()" style="display:none" />
                                        <input id="getServiceApiUrl" value="@System.Configuration.ConfigurationManager.AppSettings["ServiceApiUrl"].ToString()" style="display:none" />
                                        <input type="hidden" id="hdnSalesQuoteAction" value="@Session["BusinessPlanAction"]" />
                                    </div>
                                    <div class="col-sm-8" align="right">
                                        <table>
                                            <tr>
                                                <td>
                                                    <button id="btnAddProduct" class="btn btn-primary" type="button"><i class="bx bxs-plus-square"></i> Add Product</button>
                                                </td>
                                                <td>
                                                    <button id="btnSave" class="btn btn-success" type="button"><i class="bx bxs-save"></i> Save</button>
                                                </td>
                                                <td></td>
                                                <td>
                                                    <a href="/SPBusinessPlan/BusinessPlanContactList" class="btn btn-danger"><i class="lni lni-close"></i> Close</a>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
    <div class='loader' id='divImage' style="display:none">
        <!-- MODAL CONTENT -->
        <div class='loader-content'>
            <span class="app-loader-spinner" role="status" aria-label="Loading"></span>
        </div>
    </div>
    <div class="modal" id="modalAddNewProd" tabindex="-1" aria-hidden="true" style="display:none">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Product</h5>
                    <button id="btnCloseModalAddNewProd" type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <div class="row mb-3">
                                <label class="col-sm-3 col-form-label">Product</label>
                                <div class="col-sm-9">
                                    @*<select id="ddlProducts" class="form-select">
                                        </select>*@
                                    <input id="ddlProducts" type="text" class="form-control" /><br />
                                    <input id="hfProdNo" name="hfProdNo" value="" style="display:none" />
                                    <span id="errormsg" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <label id="lblNewProdMsg" class="form-label" style="display:none"></label>
                    &nbsp;
                    <button id="btnAddNewProdSpinner" class="btn btn-primary" type="button" disabled style="display:none">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span class="visually-hidden">Loading...</span>
                    </button>
                    &nbsp;
                    <button id="btnConfirmAddProduct" type="button" class="btn btn-primary">Add</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal" id="modalErrMsg" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" style="color:red">Error</h5>
                    <button id="btnCloseModalErrMsg" type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="color:red" align="center">
                    <img src="~/Layout/assets/images/appImages/CancelIcon.png" />
                    <br /><br />
                    <h6 id="modalErrDetails" style="color:red"></h6>
                </div>
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    <script src="~/Scripts/appjs/BusinessPlan.js"></script>
    <script>
        $(document).ready(function () {

            function checkValidEntries() {
                let enable = false;

                $("#tblCustBusinessPlan TR").each(function () {
                    var prodNo = $(this).find("TD").eq(0).html();
                    if (!prodNo) return; // skip header or invalid rows

                    var demandVal = parseFloat($("#" + prodNo + "_DemandQty").val()) || 0;
                    var targetVal = parseFloat($("#" + prodNo + "_TargetQty").val()) || 0;

                    if (demandVal > 0 || targetVal > 0) {
                        enable = true;
                        return false;
                    }
                });

                $('#btnSave').prop('disabled', !enable);
            }
            checkValidEntries();

            $(document).on('input', 'input[id$="_DemandQty"], input[id$="_TargetQty"]', function () {
                checkValidEntries();
            });
            $('#btnSave').click(function () {

                $('#divImage').show();
                var businessplan = {};
                var productDetails_ = new Array();

                businessplan.Customer_No = $('#hfCustomerNo').val();
                businessplan.PCPL_Plan_Year = $('#lblFinancialYear').text();

                $("#tblCustBusinessPlan TR").each(function () {
                    var prodNo = $(this).find("TD").eq(0).html();

                    var demandVal = parseFloat($("#" + prodNo + "_DemandQty").val()) || 0;
                    var targetVal = parseFloat($("#" + prodNo + "_TargetQty").val()) || 0;

                    if (demandVal > 0 && targetVal > 0) {
                        var productDetails = {};
                        productDetails.Product_No = prodNo;
                        productDetails.Demand = demandVal;
                        productDetails.Target = targetVal;
                        productDetails.PCPL_Target_Revenue = parseInt($(this).find("TD").eq(9).html().replace(/,/g, ""));
                        productDetails_.push(productDetails);
                    }
                });

                businessplan.Products = productDetails_;

                $.ajax({
                    type: "POST",
                    url: "/SPBusinessPlan/PostBusinessPlan",
                    data: JSON.stringify(businessplan),
                    contentType: "application/json; charset=utf-8",
                    success: function (responseMsg) {
                        $('#divImage').hide();

                        if (responseMsg.includes("Error:")) {
                            var responseMsgDetails = responseMsg.split(':');
                            $('#modalErrMsg').css('display', 'block');
                            $('#modalErrDetails').text(responseMsgDetails[1]);
                        }
                        else if (responseMsg == "True") {
                            var actionMsg = "Business Plan Updated Successfully";
                            ShowActionMsg(actionMsg);
                        }
                    }
                });
            });
        });

    </script>
